<!DOCTYPE html>
<html lang="en" dir="ltr">
  <%- include ('partials/head') %>
  <style>
    body {
      margin: 0;
      padding: 0;
    }
    #districts-attractions-map {
      /* position: absolute;  */
      width: 100%;
      height: 500px;
    }
    .mapboxgl-ctrl-attrib-inner {
      display: none;
    }
    .marker_image {
      display: block;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      padding: 0;
    }
  </style>

  <link
    rel="stylesheet"
    href="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-directions/v4.1.1/mapbox-gl-directions.css"
    type="text/css"
  />
  <body class="app sidebar-mini ltr">
    <!-- PAGE -->
    <div class="page">
      <div class="page-main">
        <!-- app-Header -->
        <%- include ('partials/header') %>

        <!-- /app-Header -->

        <!--APP-SIDEBAR-->
        <%- include ('partials/sidebar') %>

        <!--app-content open-->
        <div class="main-content app-content mt-0">
          <div class="side-app">
            <!-- CONTAINER -->
            <div class="main-container container-fluid">
              <!-- PAGE-HEADER -->
              <div class="page-header">
                <h1 class="page-title">
                  Dashboard
                  <code class="text-success"
                    >Welcome: <%= currentUser.name %> | <%= currentUser.username
                    %></code
                  >
                </h1>
                <div>
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                      <a href="javascript:void(0)">Home</a>
                    </li>
                  </ol>
                </div>
              </div>
              <!-- PAGE-HEADER END -->

              <!-- ROW-1 Total Counts -->
              <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12 col-xl-12">
                  <div class="row" id="append_total_count">
                    <!-- All total counts will append here -->
                    <div class="example text-center">
                      <div
                        class="spinner-border text-primary me-2"
                        role="status"
                      >
                        <span class="visually-hidden">Loading...</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="row">
                <div class="col-md-12 col-lg-12">
                  <div class="card">
                    <div class="col p-3">
                        <h5 class="m-3"><%= pageTitle %> List</h5>
                      </div>
                    <div class="card-body">
                      <div class="table-responsive">
                        <table
                          id="table1"
                          class="table table-sm table-hover table-condensed"
                          width="100%"
                        >
                          <thead>
                            <tr>
                              <th style="width: 1%">#</th>
                              <th style="width: 10%">Car </th>
                              <th style="width: 10%">Customer</th>
                              <th>Contact No</th>
                              <th>From Location</th>
                              <th>To Location</th>
                              <th>Pickup Time</th>
                              <th>Pickup Date</th>
                              <th>Ride Type</th>
                            </tr>
                          </thead>
                          <tbody></tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
      
            </div>
          </div>
        </div>
        <!--app-content close-->
        
      <!-- FOOTER -->
      <%- include ('partials/footer') %>

      <!-- FOOTER END -->
    </div>

    <!-- BACK-TO-TOP -->
    <a href="#top" id="back-to-top"><i class="fa fa-angle-up"></i></a>

    <%- include ('partials/footer-script') %>
    <script src="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-directions/v4.1.1/mapbox-gl-directions.js"></script>

    <script>
      $(function () {
        getTotalCounts();
      });
      const getTotalCounts = async () => {
        await $.ajax({
          url: "/ap/home/total-count",
          type: "GET",
          data: {},
          success: function (response) {
            if (response && response.success) {
              let html = "";
              $.each(response.data, function (i, item) {
                html += `<div class="col-lg-6 col-md-6 col-sm-12 col-xl-3">
                                        <div class="card overflow-hidden">
                                            <div class="card-body">
                                                <a href="${item.link}">
                                                    <div class="d-flex">
                                                            <div class="mt-2">
                                                                <h6 class="">${item.title}</h6>
                                                                <h2 class="mb-0 number-font">
                                                                    ${item.total}
                                                                </h2>
                                                            </div>
                                                            <div class="ms-auto">
                                                                <div class="chart-wrapper mt-1">
                                                                    <span class="h-8 w-9 fs-25">
                                                                        ${item.icon}
                                                                    </span>
                                                                </div>
                                                            </div>
                                                    </div>
                                                </a>
                                            </div>
                                        </div>
                                    </div>`;
              });
              $("#append_total_count").empty().append(html);
            }
          },
          error: function (xhr, errmsg, err) {
            $("#total_users").text("Error loading");
          },
        });
      };
      
    $(function () {
      let table = $("#table1").DataTable({
        searching: false,
        paging: true,
        responsive: true,
        select: true,
        order: [[0, ""]],
        pageLength: 30,
        processing: true,
        serverSide: true,
        ajax: {
          url: `/ap/home/list`,
          type: "GET",
          data: function () {},
        },
        columnDefs: [
          {
            searchable: true,
            orderable: false,
            defaultContent: "-",
            targets: "_all",
          },
        ],
        dom: "Bfrtip",
      });
    });
    </script>
  </body>
</html>
