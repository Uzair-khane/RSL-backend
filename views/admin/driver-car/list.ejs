<!DOCTYPE html>
<html lang="en" dir="ltr">
  <%- include ('../partials/head') %>

  <body class="app sidebar-mini ltr">
    <!-- PAGE -->
    <div class="page">
      <div class="page-main">
        <!-- app-Header -->
        <%- include ('../partials/header') %>
        <!-- /app-Header -->
        <!--APP-SIDEBAR-->
        <%- include ('../partials/sidebar') %>
        <!--app-content open-->
        <div class="main-content app-content mt-0">
          <div class="side-app">
            <!-- CONTAINER -->
            <div class="main-container container-fluid">
              <!-- PAGE-HEADER -->
              <div class="page-header">
                <h1 class="page-title"><%= pageTitle %></h1>
                <div>
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                      <a href="/ap/home">Home</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                      <%= pageTitle %>
                    </li>
                  </ol>
                </div>
              </div>
              <!-- PAGE-HEADER END -->
              <!-- ROW 1 -->
              <div class="row">
                <div class="col-lg-12 col-md-12">
                  <div class="card" id="addRecordForm" style="display: block">
                    <div class="card-header">
                      <h3 class="card-title">
                        <i class="fe fe-plus-circle"></i> New Assign Car
                      </h3>
                    </div>
                    <!-- ADD FORM -->
                    <div class="card-body">
                      <form
                        class=""
                        enctype="multipart/form-data"
                        id="addForm"
                        method="post"
                      >
                        <div class="form-row">
                          <div class="col-md-6 mb-2">
                            <label
                              >Select Car
                              <small class="text-info"
                                >(Which car sssign)</small
                              ></label
                            >

                            <select
                              class="form-control select2-show-search select2 type-dropdown"
                              data-placeholder="Select Type"
                              id="car"
                              name="car"
                            >
                              <option value="0" selected disabled>
                                Select Cars
                              </option>
                              <% carsdata.forEach(cars => { %>
                              <option value="<%= cars.id %>" %>
                                > <%= cars.title %>
                              </option>
                              <% }) %>
                            </select>
                          </div>
                          <div class="col-md-6 mb-2">
                            <label
                              >Select Driver<small class="text-info"
                                >(Which driver assing )</small
                              ></label
                            >
                            <select
                              class="form-control select2-show-search select2 type-dropdown"
                              data-placeholder="Select Type"
                              id="driver"
                              name="driver"
                            >
                              <option value="0" selected disabled>
                                Select Driver
                              </option>
                              <% driversdata.forEach(driver => {%>
                              <option value="<%= driver.id %>" %>
                                > <%= driver.name %>
                              </option>
                              <% }) %>
                            </select>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12 mb-2">
                            <label for="description">Description</label>
                            <textarea
                              class="form-control mb-4 summernote"
                              required
                              id="description"
                              name="description"
                            ></textarea>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12">
                            <div class="form-group pull-right">
                              <button
                                type="submit"
                                id="submit"
                                class="btn btn-sm btn-outline-success"
                              >
                                Save
                              </button>
                              <button
                                type="reset"
                                class="btn btn-sm btn-outline-info reset_form"
                              >
                                Reset
                              </button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW 1 -->
              <!-- ROW-2 -->
              <div class="row">
                <div class="col-md-12 col-lg-12">
                  <div class="card">
                    <div class="card-header">
                      <h5 class="mb-3"><%= pageTitle %> List</h5>
                    </div>
                    <div class="card-body">
                      <div class="table-responsive">
                        <table
                          id="table1"
                          class="table table-sm table-hover table-condensed"
                          width="100%"
                        >
                          <thead>
                            <tr>
                              <th style="width: 4%">#</th>
                              <th>Car</th>
                              <th style="width: 15%">Driver</th>
                              <th>Description</th>
                              <th>Created</th>
                              <th>Action</th>
                            </tr>
                          </thead>
                          <tbody></tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW-2 END -->
            </div>
            <!-- CONTAINER END -->
          </div>
        </div>
        <!--app-content close-->
      </div>

      <!-- FOOTER -->
      <%- include ('../partials/footer') %>

      <!-- FOOTER END -->
    </div>

    <!-- BACK-TO-TOP -->
    <a href="#top" id="back-to-top">
      <i class="fa fa-angle-up"></i>
    </a>
    <%- include ('../partials/footer-script') %>
  </body>
  <script>
    const actionUrl = "<%=actionUrl%>";
    $(function () {
      let table = $("#table1").DataTable({
        searching: false,
        paging: true,
        responsive: true,
        select: true,
        order: [[0, ""]],
        pageLength: 30,
        processing: true,
        serverSide: true,
        ajax: {
          url: `${actionUrl}/list`,
          type: "POST",
          data: function () {},
        },
        columnDefs: [
          {
            searchable: true,
            orderable: false,
            defaultContent: "-",
            targets: "_all",
          },
        ],
        dom: "Bfrtip",
      }); //..... end of dataTables.
    });
    // add new day
    $(document).on("submit", "#addForm", async function (e) {
      e.preventDefault();
      let formData = new FormData();
      const driver = $("#driver").val();
      const car = $("#car").val();
      const description = $("#description").summernote("code");
      formData.append("car", car);
      formData.append("driver", driver);
      formData.append("description", description);
      let table = $("#table1").DataTable();
      if (driver && car) {
        submitBtnLoader("submit", "show");
        $.ajax({
          url: `${actionUrl}/add`,
          type: "POST",
          processData: false,
          contentType: false,
          data: formData,
          success: async function (response) {
            submitBtnLoader("submit", "hide");
            if (response.success) {
              $.growl.notice1({ title: "Success", message: response.message });
              $(`#car option[value="${car}"]`).remove();
              $(`#driver option[value="${driver}"]`).remove();
              await resetForm();
              table.draw();
            } else {
              $.growl.error1({ title: "Error! 1", message: response.message });
            }
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          },
          error: function (xhr, errmsg, err) {
            submitBtnLoader("submit", "hide");
            $.growl.error1({ title: "Error!", message: err + errmsg });
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          },
        });
      }
    });
    // revoke record hard
    function revokeRecord(id, table) {
      let table1 = $("#table1").DataTable();
      swal(
        {
          title: "Are you sure?",
          text: "You want to revoke this permanently!",
          type: "error",
          icon: "warning",
          showCancelButton: true,
          confirmButtonText: "Yes, revoke it!",
          cancelButtonText: "Cancel",
        },
        function (result) {
          if (result) {
            $.ajax({
              url: `/ap/driver-car/revoke`,
              type: "POST",
              data: {
                id: id,
                source_table: table,
              },
              success: function (response) {
                if (response && response.success) {
                
                  $.growl.notice1({
                    title: "Success",
                    message: response.message,
                  });                  
                  $("#driver").append(
                    `<option value="${driverId}">${response.driverName}</option>`
                  );
                  $("#car").append(
                    `<option value="${carId}">${response.carTitle}</option>`
                  );
                  table1.draw();
                } else {
                  $.growl.error1({
                    title: "Error1!",
                    message: response.message,
                  });
                }
              },
              error: function (xhr, errmsg, err) {
                $.growl.error1({ title: "Error!", message: response.message });
              },
            });
          }
        }
      );
    }

    // RESET FORM
    $(".reset_form").click(async function () {
      await resetForm();
      // scroll top
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // reset form
    function resetForm() {
      $("#driver").val();
      $("#car").val();
      $("#addForm")[0].reset();
      $("#editForm")[0].reset();
      $(".summernote").summernote("code", "");
      $("#type").val("footer").trigger("change");
    }
  </script>
</html>
