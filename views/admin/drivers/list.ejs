<!DOCTYPE html>
<html lang="en" dir="ltr">
  <%- include ('../partials/head') %>
  <body class="app sidebar-mini ltr">
    <!-- PAGE -->
    <div class="page">
      <div class="page-main">
        <!-- app-Header -->
        <%- include ('../partials/header') %>
        <!-- /app-Header -->
        <!--APP-SIDEBAR-->
        <%- include ('../partials/sidebar') %>
        <!--app-content open-->
        <div class="main-content app-content mt-0">
          <div class="side-app">
            <!-- CONTAINER -->
            <div class="main-container container-fluid">
              <!-- PAGE-HEADER -->
              <div class="page-header">
                <h1 class="page-title"><%= pageTitle %></h1>
                <div>
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                      <a href="/ap/home">Home</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                      <%= pageTitle %>
                    </li>
                  </ol>
                </div>
              </div>
              <!-- PAGE-HEADER END -->
              <!-- ROW 1 -->
              <div class="row">
                <div class="col-lg-12 col-md-12">
                  <div class="card" id="addRecordForm" style="display: block">
                    <div class="card-header">
                      <h3 class="card-title">
                        <i class="fe fe-plus-circle"></i> Add New Driver
                      </h3>
                    </div>
                    <!-- ADD FORM -->
                    <div class="card-body">
                      <form
                        class=""
                        enctype="multipart/form-data"
                        id="addForm"
                        method="post"
                      >
                        <div class="form-row">
                          <div class="col-md-5 mb-2">
                            <label for="name"
                              >Name<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="name"
                              id="name"
                              placeholder="Enter you name"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="contact"
                              >Contact No<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="contact"
                              id="contact"
                              placeholder="Enter your contact no"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="license_no"
                              >License No<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="license_no"
                              id="license_no"
                              placeholder="Enter license no"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="id_card_no"
                              >ID Card No<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="id_card_no"
                              id="id_card_no"
                              placeholder="Enter ID card no"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="passport_no"
                              >Passport No<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="passport_no"
                              id="passport_no"
                              placeholder="Enter passport no"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="address"
                              >Address<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="address"
                              id="address"
                              placeholder="Enter your address"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="dob"
                              >Date Of Birth<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="date"
                              class="form-control"
                              name="dob"
                              id="dob"
                              placeholder="Enter Date of Birth"
                              required
                            />
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12 mb-2">
                            <label for="description"
                              >Description
                              <small class="text-info">(if any)</small></label
                            >
                            <textarea
                              class="form-control mb-4 summernote"
                              id="description"
                              name="description"
                            ></textarea>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12">
                            <div class="form-group pull-right">
                              <button
                                type="submit"
                                id="submit"
                                class="btn btn-sm btn-outline-success"
                              >
                                Save
                              </button>
                              <button
                                type="reset"
                                class="btn btn-sm btn-outline-info reset_form"
                              >
                                Reset
                              </button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                  <div class="card" id="editRecordForm" style="display: none">
                    <div class="card-header">
                      <h3 class="card-title">
                        <i class="fe fe-edit"></i> Update Record
                      </h3>
                    </div>
                    <!-- EDIT FORM -->
                    <div class="card-body">
                      <form
                        class=""
                        enctype="multipart/form-data"
                        id="editForm"
                        method="post"
                      >
                        <input
                          type="hidden"
                          name="driver_id_edit"
                          id="driver_id_edit"
                          value=""
                        />
                        <div class="form-row">
                          <div class="col-md-5 mb-2">
                            <label for="name_edit"
                              >Name<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="name"
                              id="name_edit"
                              placeholder="Enter your name"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="contact_no_edit"
                              >Contact no<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="contact_no"
                              id="contact_no_edit"
                              placeholder="Enter your name"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="license_no_edit"
                              >License no<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="license_no"
                              id="license_no_edit"
                              placeholder="Enter License no"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="id_card_no_edit"
                              >ID Card no<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="id_card_no"
                              id="id_card_no_edit"
                              placeholder="Enter ID card no"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="passport_no_edit"
                              >Passport No<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="passport_no"
                              id="passport_no_edit"
                              placeholder="Enter passport no"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="address_edit"
                              >Address<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="address"
                              id="address_edit"
                              placeholder="Enter Address"
                              required
                            />
                          </div>
                          <div class="col-md-5 mb-2">
                            <label for="dob_edit"
                              >Date of birth<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="date"
                              class="form-control"
                              name="dob"
                              id="dob_edit"
                              placeholder="Enter your name"
                              required
                            />
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12 mb-2">
                            <label for="description_edit"
                              >Description
                              <small class="text-info">(if any)</small></label
                            >
                            <textarea
                              class="form-control mb-4 summernote"
                              id="description_edit"
                              name="description_edit"
                            ></textarea>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12">
                            <div class="form-group pull-right">
                              <button
                                type="submit"
                                id="submitEdit"
                                class="btn btn-sm btn-outline-success"
                              >
                                Update
                              </button>
                              <button
                                type="reset"
                                class="btn btn-sm btn-outline-info reset_form"
                              >
                                Cancel
                              </button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW 1 -->
              <!-- ROW-2 -->
              <div class="row">
                <div class="col-md-12 col-lg-12">
                  <div class="card">
                    <div class="card-header">
                      <h5 class="mb-3"><%= pageTitle %> List</h5>
                    </div>
                    <div class="card-body">
                      <div class="table-responsive">
                        <table
                          id="table1"
                          class="table table-sm table-hover table-condensed"
                          width="100%"
                        >
                          <thead>
                            <tr>
                              <th style="width: 4%">#</th>
                              <th style="width: 10%">Name</th>
                              <th>Conatct</th>
                              <th>License No</th>
                              <th>ID Card No</th>
                              <th>Passport No</th>
                              <th>Address</th>
                              <th>Date of birth</th>
                              <th>Description</th>
                              <th style="width: 2%">Status</th>
                              <th style="width: 5%">Created</th>
                              <th style="width: 8%">Action</th>
                            </tr>
                          </thead>
                          <tbody></tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW-2 END -->
            </div>
            <!-- CONTAINER END -->
          </div>
        </div>
        <!--app-content close-->
      </div>

      <!-- FOOTER -->
      <%- include ('../partials/footer') %>

      <!-- FOOTER END -->
    </div>

    <!-- BACK-TO-TOP -->
    <a href="#top" id="back-to-top">
      <i class="fa fa-angle-up"></i>
    </a>
    <%- include ('../partials/footer-script') %>
  </body>
  <script>
    const actionUrl = "<%=actionUrl%>";
    $(function () {
      let table = $("#table1").DataTable({
        searching: false,
        paging: true,
        responsive: true,
        select: true,
        order: [[0, ""]],
        pageLength: 30,
        processing: true,
        serverSide: true,
        ajax: {
          url: `${actionUrl}/list`,
          type: "POST",
          data: function () {},
        },
        columnDefs: [
          {
            searchable: true,
            orderable: false,
            defaultContent: "-",
            targets: "_all",
          },
        ],
        dom: "Bfrtip",
      }); //..... end of dataTables.
    });

    // add new day
    $(document).on("submit", "#addForm", async function (e) {
      e.preventDefault();
      let formData = new FormData();
      const name = $("#name").val();
      const contact = $("#contact").val();
      const license_no = $("#license_no").val();
      const id_card_no = $("#id_card_no").val();
      const passport_no = $("#passport_no").val();
      const address = $("#address").val();
      const dob = $("#dob").val();
      const description = $("#description").summernote("code");

      formData.append("name", name);
      formData.append("contact", contact);
      formData.append("license_no", license_no);
      formData.append("id_card_no", id_card_no);
      formData.append("passport_no", passport_no);
      formData.append("address", address);
      formData.append("dob", dob);
      formData.append("description", description);

      let table = $("#table1").DataTable();
      if (name.trim() != "") {
        submitBtnLoader("submit", "show");
        $.ajax({
          url: `${actionUrl}/add`,
          type: "POST",
          processData: false,
          contentType: false,
          data: formData,
          success: async function (response) {
            submitBtnLoader("submit", "hide");
            if (response.success) {
              $.growl.notice1({ title: "Success", message: response.message });
              await resetForm();
              table.draw();
            } else {
              $.growl.error1({ title: "Error! 1", message: response.message });
            }
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          },
          error: function (xhr, errmsg, err) {
            submitBtnLoader("submit", "hide");
            $.growl.error1({ title: "Error! 2", message: err + errmsg });
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          },
        });
      }
    });

    // edit record
    function editRecord(id, table) {
      $.ajax({
        url: `/ap/general/edit/record`,
        type: "POST",
        data: { id: id, source_table: table },
        success: function (response) {
          if (response && response.success) {
            $("#addRecordForm").css("display", "none");
            $("#editRecordForm").css("display", "block");
            // $('.dropify-render img').remove();
            $("#driver_id_edit").val(id);
            $("#name_edit").val(response.data.name);
            $("#contact_no_edit").val(response.data.contact);
            $("#license_no_edit").val(response.data.license_no);
            $("#id_card_no_edit").val(response.data.id_card_no);
            $("#passport_no_edit").val(response.data.passport_no);
            $("#address_edit").val(response.data.address);
            $("#dob_edit").val(response.data.dob);
            $("#description_edit").summernote(
              "code",
              response.data.description
            );
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        },
        error: function (xhr, errmsg, err) {
          $.growl.error1({ title: "Error!", message: err + errmsg });
        },
      });
    }

    // udpate record
    $(document).on("submit", "#editForm", async function (e) {
      e.preventDefault();
      let formData = new FormData();
      const id = $("#driver_id_edit").val();
      const name = $("#name_edit").val();
      const contact = $("#contact_edit").val();
      const license_no = $("#license_no_edit").val();
      const id_card_no = $("#id_card_no_edit").val();
      const passport_no = $("#passport_no_edit").val();
      const address = $("#address_edit").val();
      const dob = $("#dob_edit").val();
      const description = $("#description_edit").summernote("code");

      formData.append("id", id);
      formData.append("name", name);
      formData.append("contact", contact);
      formData.append("license_no", license_no);
      formData.append("id_card_no", id_card_no);
      formData.append("passport_no", passport_no);
      formData.append("address", address);
      formData.append("dob", dob);
      formData.append("description", description);

      let table = $("#table1").DataTable();
      if (id != "" && name.trim() != "") {
        submitBtnLoader("submitEdit", "show");
        $.ajax({
          url: `${actionUrl}/update`,
          type: "POST",
          processData: false,
          contentType: false,
          data: formData,
          success: async function (response) {
            submitBtnLoader("submitEdit", "hide");
            if (response.success) {
              $.growl.notice1({ title: "Success", message: response.message });
              await resetForm();
              table.draw();
            } else {
              $.growl.error1({ title: "Error!", message: response.message });
            }
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          },
          error: function (xhr, errmsg, err) {
            submitBtnLoader("submitEdit", "hide");
            $.growl.error1({ title: "Error!", message: err + "." + errmsg });
          },
        });
      }
    });

    // delete record hard
    function deleteRecord(id, table) {
      let table1 = $("#table1").DataTable();
      swal(
        {
          title: "Are you sure?",
          text: "You want to delete this permanently!",
          type: "error",
          icon: "warning",
          showCancelButton: true,
          confirmButtonText: "Yes, delete it!",
          cancelButtonText: "Cancel",
        },
        function (result) {
          if (result) {
            $.ajax({
              url: `/ap/general/delete/record`,
              type: "POST",
              data: {
                id: id,
                source_table: table,
              },
              success: function (response) {
                if (response && response.success) {
                  $.growl.notice1({
                    title: "Success",
                    message: response.message,
                  });
                  table1.draw();
                } else {
                  $.growl.error1({
                    title: "Error!",
                    message: response.message,
                  });
                }
              },
              error: function (xhr, errmsg, err) {
                $.growl.error1({ title: "Error!", message: response.message });
              },
            });
          }
        }
      );
    }

    // RESET FORM
    $(".reset_form").click(async function () {
      await resetForm();
      // scroll top
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // reset form
    function resetForm() {
      $("#addForm")[0].reset();
      $("#editForm")[0].reset();
      $(".summernote").summernote("code", "");
      $("#department_id_edit").val("");
      $("#d_type").val("dol").trigger("change");
      $("#d_type_edit").val("dol").trigger("change");
      $("#addRecordForm").css("display", "block");
      $("#editRecordForm").css("display", "none");
      // Dropify IMAGE
      $(".dropify-render img").remove();
      $(".dropify-preview").css("display", "none");
      $(".dropify-clear").css("display", "none");
      $(".dropify-loader").css("display", "none");
      $(".dropify-message").css("display", "block");
    }
  </script>
</html>
