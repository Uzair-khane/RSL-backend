<!DOCTYPE html>
<html lang="en" dir="ltr">
<%- include ('./partials/head') %>

  <body class="app sidebar-mini ltr">
    <!-- PAGE -->
    <div class="page">
      <div class="page-main">
        <!-- app-Header -->
        <%- include ('./partials/header') %>
          <!-- /app-Header -->
          <!--APP-SIDEBAR-->
          <%- include ('./partials/sidebar') %>
            <!--app-content open-->
            <div class="main-content app-content mt-0">
              <div class="side-app">
                <!-- CONTAINER -->
                <div class="main-container container-fluid">
                  <!-- PAGE-HEADER -->
                  <div class="page-header">
                    <h1 class="page-title">
                      <%= pageTitle %>
                    </h1>
                    <div>
                      <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                          <a href="/ap/home">Home</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                          <%= pageTitle %>
                        </li>
                      </ol>
                    </div>
                  </div>
                  <!-- PAGE-HEADER END -->

                  <!-- ROW 1 -->
                  <!-- ROW-2 -->
                  <div class="row">
                    <div class="col-md-12 col-lg-12">
                      <div class="card">
                        <div class="card-header">
                          <h5 class="mb-3">
                            <%= pageTitle %> List
                          </h5>
                        </div>
                        <div class="card-body">
                          <div class="table-responsive">
                            <table id="table1" class="table table-sm table-hover table-condensed" width="100%">
                              <thead>
                                <tr>
                                  <th style="width: 4%">#</th>
                                  <th style="width: 20%">Title</th>
                                  <th style="width: 12%">User Name</th>
                                  <th>Description</th>
                                  <th>Created</th>
                                  <!-- <th style="width: 18%">Action</th> -->
                                </tr>
                              </thead>
                              <tbody></tbody>
                            </table>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <!-- ROW-2 END -->
                </div>
                <!-- CONTAINER END -->
              </div>
            </div>
            <!--app-content close-->
      </div>

      <!-- FOOTER -->
      <%- include ('./partials/footer') %>

        <!-- FOOTER END -->
    </div>

    <!-- BACK-TO-TOP -->
    <a href="#top" id="back-to-top">
      <i class="fa fa-angle-up"></i>
    </a>
    <%- include ('./partials/footer-script') %>
  </body>
  <script>
    const actionUrl = "<%=actionUrl%>";
    $(function () {
      let table = $("#table1").DataTable({
        searching: false,
        paging: true,
        responsive: true,
        select: true,
        order: [[0, ""]],
        pageLength: 30,
        processing: true,
        serverSide: true,
        ajax: {
          url: `${actionUrl}/list`,
          type: "POST",
          data: function () { },
        },
        columnDefs: [
          {
            searchable: true,
            orderable: false,
            defaultContent: "-",
            targets: "_all",
          },
        ],
        dom: "Bfrtip",
      }); //..... end of dataTables.
    });


    // delete record hard
    function deleteRecord(id, table) {
      let table1 = $("#table1").DataTable();
      swal(
        {
          title: "Are you sure?",
          text: "You want to delete this permanently!",
          type: "error",
          icon: "warning",
          showCancelButton: true,
          confirmButtonText: "Yes, delete it!",
          cancelButtonText: "Cancel",
        },
        function (result) {
          if (result) {
            $.ajax({
              url: `/ap/general/delete/record`,
              type: "POST",
              data: {
                id: id,
                source_table: table,
              },
              success: function (response) {
                if (response && response.success) {
                  $.growl.notice1({
                    title: "Success",
                    message: response.message,
                  });
                  table1.draw();
                } else {
                  $.growl.error1({
                    title: "Error!",
                    message: response.message,
                  });
                }
              },
              error: function (xhr, errmsg, err) {
                $.growl.error1({ title: "Error!", message: response.message });
              },
            });
          }
        }
      );
    }
  </script>

</html>