<!DOCTYPE html>
<html lang="en" dir="ltr">
  <%- include ('../partials/head') %>

  <body class="app sidebar-mini ltr">
    <!-- PAGE -->
    <div class="page">
      <div class="page-main">
        <!-- app-Header -->
        <%- include ('../partials/header') %>
        <!-- /app-Header -->
        <!--APP-SIDEBAR-->
        <%- include ('../partials/sidebar') %>
        <!--app-content open-->
        <div class="main-content app-content mt-0">
          <div class="side-app">
            <!-- CONTAINER -->
            <div class="main-container container-fluid">
              <!-- PAGE-HEADER -->
              <div class="page-header">
                <h1 class="page-title"><%= pageTitle %></h1>
                <div>
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                      <a href="/ap/home">Home</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                      <%= pageTitle %>
                    </li>
                  </ol>
                </div>
              </div>
              <!-- ROW-2 -->
              <div class="row">
                <div class="d-flex justify-content-end mb-3 font-weight-bold ">
                 <a href="/ap/accounts-history/list" class="btn btn-primary btn-wave waves-effect waves-light w-25 p-2 fw-bolder fs-6">
                  <span class="me-3"><i class="fa fa-list"></i></span>
                  Accounts History
                 </a>
                </div>
                <div class="col-md-12 col-lg-12">
                  <div class="card">
                    <div
                      class="card-header row justify-content-between align-items-center"
                    >
                      <div class="col">
                        <h5 class="mb-3"><%= pageTitle %> List</h5>
                      </div>
                      <div class="col">
                        <select
                          class="form-control select2-show-search type-dropdown"
                          data-placeholder="Select Type"
                          id="filter_driver"
                          name="filter_driver"
                        >
                          <option value="0" selected disabled>
                            Check By Driver
                          </option>
                          <% driversData.forEach(driver=> { %>
                          <option value="<%= driver.id %>" %>
                            > <%= driver.name %>
                          </option>
                          <% }) %>
                        </select>
                      </div>
                    </div>
                    <div class="card-body">
                      <div class="table-responsive">
                        <table
                          id="table1"
                          class="table table-sm table-hover table-condensed"
                          width="100%"
                        >
                          <thead>
                            <tr>
                              <th style="width: 1%">#</th>
                              <th>Driver</th>
                              <th>Account</th>
                              <th>Amount Status</th>
                            </tr>
                          </thead>
                          <tbody></tbody>
                        </table>
                      </div>
                    </div>
                    <div class="card-body">
                      <form
                        id="addForm"
                        method="post"
                        enctype="multipart/form-data"
                      >
                        <div class="form-row">
                          <div class="col-md-2 mb-2">
                            <label for="total"
                              >Total Amount<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="total"
                              id="total"
                            />
                          </div>
                          <div class="col-md-3 mb-2">
                            <label for="recived_amount"
                              >Received Amount<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="received_amount"
                              id="received_amount"
                              placeholder="Enter Received Amount"
                              required
                            />
                          </div>
                          <div class="col-md-2 mb-2">
                            <label for="remaining_amount"
                              >Remaining Amount<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="remaining_amount"
                              id="remaining_amount"
                            />
                          </div>
                          <div class="col-md-3 mb-2">
                            <label for="description"
                              >Note<sup class="text-danger">*</sup></label
                            >
                            <textarea
                              rows="1"
                              class="form-control"
                              name="description"
                              id="description"
                              placeholder="Enter Note"
                            ></textarea>
                          </div>
                          <div class="col-md-2" style="margin-top: 28px">
                            <button
                              type="button"
                              id="collectAmountBtn"
                              class="btn btn-outline-success"
                            >
                              Collect Amount
                            </button>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW-2 END -->
            </div>
            <!-- CONTAINER END -->
          </div>
        </div>
        <!--app-content close-->
      </div>

      <!-- FOOTER -->
      <%- include ('../partials/footer') %>

      <!-- FOOTER END -->
    </div>

    <!-- BACK-TO-TOP -->
    <a href="#top" id="back-to-top">
      <i class="fa fa-angle-up"></i>
    </a>
    <%- include ('../partials/footer-script') %>
  </body>
  <script>
    const actionUrl = "<%=actionUrl%>";
    let totalAmount = 0;
    let bookingIds = [];

    $(function () {
      // Initialize DataTable
      let table = $("#table1").DataTable({
        searching: false,
        paging: true,
        responsive: true,
        select: true,
        order: [[0, ""]],
        pageLength: 30,
        processing: true,
        serverSide: true,
        ajax: {
          url: `${actionUrl}/list`,
          type: "POST",
          data: function (d) {
            d.filter_driver = $("#filter_driver").val();
          },
          dataSrc: function (json) {
            // Update totalAmount from server response
            totalAmount = json.totalAmount;
            bookingIds = json.bookingIds;
            updateTotalAmount();
            return json.data;
          },
        },
        columnDefs: [
          {
            searchable: true,
            orderable: false,
            defaultContent: "-",
            targets: "_all",
          },
        ],
        dom: "Bfrtip",
      });

      // Update Total Amount Field
      function updateTotalAmount() {
        $("#total").val(`${totalAmount}`);
        let re = $("#received_amount").val(`${totalAmount}`);
        $("#remaining_amount").val(`${"0"}`);
      }

      // Reload DataTable on driver filter change
      $(document).on("change keyup", ".type-dropdown", function () {
        table.ajax.reload();
      });

      // Auto-refresh logic
      setInterval(() => {
        if ($("#auto_refresh_list").is(":checked")) {
          table.ajax.reload();
        }
      }, 10000);

      $(document).on("click", "#auto_refresh_list", function () {
        $("#auto_fetch_spinner").toggle($("#auto_refresh_list").is(":checked"));
      });

      // Get Table Data Utility Function
      function getTableData(tableId) {
        const table = document.getElementById(tableId);
        const rows = table.querySelectorAll("tbody tr");
        const tableData = [];

        rows.forEach((row) => {
          const rowData = [];
          const cells = row.querySelectorAll("td");
          cells.forEach((cell) => {
            rowData.push(cell.textContent);
          });
          tableData.push(rowData);
        });

        return tableData;
      }

      // Example Usage:
      const tableData = getTableData("table1");

      // Amount Collect Function
      $(document).on("click", "#collectAmountBtn", async function (e) {
        e.preventDefault();
        let formData = new FormData();

        const total = $("#total").val();
        const received_amount = $("#received_amount").val();
        const remaining_amount = $("#remaining_amount").val();
        const description = $("#description").val();

        // Create FormData
        formData.append("total", total);
        formData.append("received_amount", received_amount);
        formData.append("remaining_amount", remaining_amount);
        formData.append("description", description);

        formData.append("bookingIds", JSON.stringify(bookingIds));
        let driver_id = $("#filter_driver").val();
        formData.append("driver_id", driver_id);
        // let table = $("#table1").DataTable();
        if (total && received_amount) {
          submitBtnLoader("collectAmountBtn", "show");
          $.ajax({
            url: `${actionUrl}/update`,
            type: "POST",
            processData: false,
            contentType: false,
            data: formData,
            success: async function (response) {
              submitBtnLoader("collectAmountBtn", "hide");
              if (response.success) {
                $.growl.notice1({
                  title: "Success",
                  message: response.message,
                });
                window.location.reload();
                // // await resetForm();
                // table.draw();
              } else {
                $.growl.error1({
                  title: "Error! 1",
                  message: response.message,
                });
              }
              // scroll top
              window.scrollTo({ top: 0, behavior: "smooth" });
            },
            error: function (xhr, errmsg, err) {
              submitBtnLoader("submit", "hide");
              $.growl.error1({ title: "Error! 2", message: err + errmsg });
              // scroll top
              window.scrollTo({ top: 0, behavior: "smooth" });
            },
          });
        }
      });

      // Reset Form
      $(".reset_form").click(async function () {
        await resetForm();
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
      function resetForm() {
        // Reset form logic if needed
      }
    });
  </script>
</html>
