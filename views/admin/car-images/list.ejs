<!DOCTYPE html>
<html lang="en" dir="ltr">
  <%- include ('../partials/head') %>

  <body class="app sidebar-mini ltr">
    <!-- PAGE -->
    <div class="page">
      <div class="page-main">
        <!-- app-Header -->
        <%- include ('../partials/header') %>
        <!-- /app-Header -->
        <!--APP-SIDEBAR-->
        <%- include ('../partials/sidebar') %>
        <!--app-content open-->
        <div class="main-content app-content mt-0">
          <div class="side-app">
            <!-- CONTAINER -->
            <div class="main-container container-fluid">
              <!-- PAGE-HEADER -->
              <div class="page-header">
                <h1 class="page-title"><%= pageTitle %></h1>
                <div>
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                      <a href="/ap/home">Home</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                      <%= pageTitle %>
                    </li>
                  </ol>
                </div>
              </div>
              <!-- PAGE-HEADER END -->
              <!-- ROW 1 -->
              <div class="row">
                <div class="col-lg-12 col-md-12">
                  <div class="card" id="addRecordForm" style="display: block">
                    <div class="card-header">
                      <h3 class="card-title">
                        <i class="fe fe-plus-circle"></i> Add Car New Images
                      </h3>
                    </div>

                    <!-- ADD FORM -->
                    <div class="card-body">
                      <form
                        class=""
                        enctype="multipart/form-data"
                        id="addForm"
                        method="post"
                      >
                        <div
                          style="
                            height: 100px;
                            position: relative;
                            cursor: pointer;
                            border: 1px solid black;
                          "
                          class="form-group d-flex justify-content-center align-items-center w-100 mb-0"
                        >
                          <p>Select file</p>
                          <input
                            id="demo"
                            style="position: absolute; opacity: 0"
                            type="file"
                            name="files"
                            accept=".jpg, .png, image/jpeg, image/png"
                            multiple
                            class="w-100 h-100"
                          />
                        </div>
                        <div class="w-100" id="imagePreview"></div>

                        <div class="form-row mt-2">
                          <div class="col-md-12">
                            <div class="form-group pull-right">
                              <button
                                type="submit"
                                id="submit"
                                class="btn btn-sm btn-outline-success"
                              >
                                Save
                              </button>
                              <button
                                type="reset"
                                class="btn btn-sm btn-outline-info reset_form"
                              >
                                Reset
                              </button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                  <div class="card" id="editRecordForm" style="display: none">
                    <div class="card-header">
                      <h3 class="card-title">
                        <i class="fe fe-edit"></i> Update Record
                      </h3>
                    </div>
                    <!-- EDIT FORM -->
                    <div class="card-body">
                      <form
                        class=""
                        enctype="multipart/form-data"
                        id="editForm"
                        method="post"
                      >
                        <input
                          type="hidden"
                          name="car_id_edit"
                          id="car_id_edit"
                          value=""
                        />
                        <div class="col-md-4 mb-2">
                          <label for="image_url_edit"
                            >Display Image<sup class="text-danger"
                              >*</sup
                            ></label
                          >
                          <input
                            type="file"
                            class="dropify"
                            data-bs-height="180"
                            name="image_url"
                            id="image_url_edit"
                            multiple
                          />
                        </div>
                        <div class="form-row">
                          <div class="col-md-12">
                            <div class="form-group pull-right">
                              <button
                                type="submit"
                                id="submitEdit"
                                class="btn btn-sm btn-outline-success"
                              >
                                Update
                              </button>
                              <button
                                type="reset"
                                class="btn btn-sm btn-outline-info reset_form"
                              >
                                Cancel
                              </button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW 1 -->
              <!-- ROW-2 -->
              <div class="row">
                <div class="col-md-12 col-lg-12">
                  <div class="card">
                    <div class="card-header">
                      <h5 class="mb-3"><%= pageTitle %> List</h5>
                    </div>
                    <div class="card-body">
                      <div class="table-responsive">
                        <table
                          id="table1"
                          class="table table-sm table-hover table-condensed"
                          width="100%"
                        >
                          <thead>
                            <tr>
                              <th style="width: 4%">#</th>
                              <th style="width: 30%">Images</th>
                              <th>Status</th>
                              <th style="width: 9%">Action</th>
                            </tr>
                          </thead>
                          <tbody></tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW-2 END -->
            </div>
            <!-- CONTAINER END -->
          </div>
        </div>
        <!--app-content close-->
      </div>

      <!-- FOOTER -->
      <%- include ('../partials/footer') %>

      <!-- FOOTER END -->
    </div>

    <!-- BACK-TO-TOP -->
    <a href="#top" id="back-to-top">
      <i class="fa fa-angle-up"></i>
    </a>
    <%- include ('../partials/footer-script') %>
    <!-- FILE UPLOADES JS -->
    <!-- INTERNAL File-Uploads Js-->
  </body>

  <script>
    const demo = document.querySelector("#demo");
    const files = [];

    demo.addEventListener("change", () => {
      const previewContainer = document.getElementById("imagePreview"); // Target the preview container
      previewContainer.innerHTML = ""; // Clear any previous previews

      // Loop through each selected file
      Array.from(demo.files).forEach((file) => {
        if (file.type.startsWith("image/")) {
          // Check if the file is an image
          files.push(demo.files);
          const img = document.createElement("img");
          img.src = URL.createObjectURL(file); // Create a temporary object URL
          img.style.width = "100px"; // Optional: Set image size
          img.style.margin = "10px";
          img.style.height = "100px";
          img.onload = () => URL.revokeObjectURL(img.src); // Revoke the object URL after image loads
          previewContainer.appendChild(img); // Append to the container
        }
      });
    });
    const actionUrl = "<%=actionUrl%>";
    const carid = "<%=carId%>";

    $(function () {
      let table = $("#table1").DataTable({
        searching: false,
        paging: true,
        responsive: true,
        select: true,
        order: [[0, ""]],
        pageLength: 30,
        processing: true,
        serverSide: true,
        ajax: {
          url: `${actionUrl}/list/${carid}`,
          type: "POST",
          data: function () {},
        },
        columnDefs: [
          {
            searchable: true,
            orderable: false,
            defaultContent: "-",
            targets: "_all",
          },
        ],
        dom: "Bfrtip",
      }); //..... end of dataTables.
    });

    $(document).ready(function () {
      // add Picture Upload
      $(document).on("submit", "#addForm", async function (e) {
        e.preventDefault();
        let formData = new FormData();
        formData.append("id", carid);
        // Read selected files
        $.each($("#demo")[0].files, function (i, file) {
          formData.append("image", file);
        });
        if (formData) {
          submitBtnLoader("submit", "show");
          $.ajax({
            url: `${actionUrl}/add/${carid}`,
            type: "POST",
            processData: false,
            contentType: false,
            data: formData,
            success: async function (response) {
              submitBtnLoader("submit", "hide");
              if (response.success) {
                $.growl.notice1({
                  title: "Success",
                  message: response.message,
                });
              } else {
                $.growl.error1({ title: "Response Error!", message: response.message });
              }
            },
            error: function (xhr, errmsg, err) {
              submitBtnLoader("submit", "hide");
              $.growl.error1({ title: "Error!", message: err });
            },
          });
        } else {
          $.growl.error1({
            title: "Error!",
            message: "Select Atleast One Image..!",
          });
        }
      });
    });

    // delete record hard
    function deleteRecord(id, table) {
      let table1 = $("#table1").DataTable();
      swal(
        {
          title: "Are you sure?",
          text: "You want to delete all images permanently!",
          type: "error",
          icon: "warning",
          showCancelButton: true,
          confirmButtonText: "Yes, delete it!",
          cancelButtonText: "Cancel",
        },
        function (result) {
          if (result) {
            $.ajax({
              url: `/ap/general/delete/record`,
              type: "POST",
              data: {
                id: id,
                source_table: table,
              },
              success: function (response) {
                if (response && response.success) {
                  $.growl.notice1({
                    title: "Success",
                    message: response.message,
                  });
                  table1.draw();
                } else {
                  $.growl.error1({
                    title: "Error!",
                    message: response.message,
                  });
                }
              },
              error: function (xhr, errmsg, err) {
                $.growl.error1({ title: "Error!", message: response.message });
              },
            });
          }
        }
      );
    }

    // RESET FORM
    $(".reset_form").click(async function () {
      await resetForm();
      // scroll top
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // reset form
    function resetForm() {
      $("#addForm")[0].reset();
      $(".summernote").summernote("code", "");
      $("#addRecordForm").css("display", "block");
      // Dropify IMAGE
      $(".dropify-render img").remove();
      $(".dropify-preview").css("display", "none");
      $(".dropify-clear").css("display", "none");
      $(".dropify-loader").css("display", "none");
      $(".dropify-message").css("display", "block");
    }
  </script>
</html>
