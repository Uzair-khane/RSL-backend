<!doctype html>
<html lang="en" dir="ltr">
    <%- include ('../partials/head') %>
    <body class="app sidebar-mini ltr">
        <!-- GLOBAL-LOADER -->
        <div id="global-loader" style="display: none;">
            <img src="/admin/images/Animation.gif" class="loader-img" alt="Loader">
        </div>
        <!-- /GLOBAL-LOADER -->
        <!-- PAGE -->
        <div class="page">
            <div class="page-main">
                <!-- app-Header -->
                <%- include ('../partials/header') %>
                <!-- /app-Header -->
                <!--APP-SIDEBAR-->
                <%- include ('../partials/sidebar') %>
                <!--app-content open-->
                    <div class="main-content app-content mt-0"> 
                        <div class="side-app">
                        <!-- CONTAINER -->
                        <div
                            class="main-container container-fluid">
                            
                            <!-- PAGE-HEADER -->
                            <div class="page-header">
                                
                                <h1 class="page-title">
                                    <%= pageTitle %>
                                </h1>
                                <div>
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item">
                                            <a href="/ap/home">Home</a>
                                        </li>
                                        <li class="breadcrumb-item                                                                                                   active" aria-current="page">
                                            <%= pageTitle %>
                                        </li>
                                    </ol>
                                </div>
                            </div>
                            <% if ( successFlash.length> 0 ) { %>
                                <div class="alert alert-success  alert-dismissible fade show" role="alert">
                                    <span class="alert-inner--icon"><i class="fe fe-thumbs-up"></i></span>
                                    <span class="alert-inner--text"><strong>Success! </strong><%= successFlash %></span>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <% } %>
                                <% if ( errorFlash.length> 0 ) { %>
                                <div class="alert alert-danger  alert-dismissible fade show" role="alert">
                                    <span class="alert-inner--icon"><i class="fe fe-info"></i></span>
                                    <span class="alert-inner--text"><strong>Error! </strong><%= errorFlash %></span>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                            <% } %>
                            <!-- PAGE-HEADER END -->
                                <!-- ROW 1 -->
                                <div class="row">
                                    <!-- Col 1 -->
                                    <div class="col-md-7 col-lg-7">
                                        <div class="card">
                                            <div class="card-header">
                                                <h3 class="card-title"><%= pageTitle %> List</h3>
                                            </div>
                                            <div class="card-body">
                                                <div class="table-responsive">
                                                    <table id="table1" class="table table-sm table-hover table-condensed text-nowrap mb-0" width="100%">
                                                        <thead>
                                                            <tr>
                                                                <th>#</th>
                                                                <th>Role</th>
                                                                <th style="width: 15%;">Status</th>
                                                                <th style="width: 15%;">Manage Role</th>
                                                                <th style="width: 10%;">Action</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody> 
                                                        </tbody>
                                                        <tfoot>
                                                            <tr>
                                                                <th>#</th>
                                                                <th>Role</th>
                                                                <th style="width: 15%;">Status</th>
                                                                <th style="width: 15%;">Manage Role</th>
                                                                <th style="width: 10%;">Action</th>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Col 2 -->
                                    <div class="col-lg-5 col-md-5">
                                        <div class="card" id="addRecordForm" style="display: block;">
                                            <div class="card-header">
                                                <h3 class="card-title"><i class="fe fe-plus-circle"></i> Add New Record</h3>
                                            </div>
                                            <!-- ADD FORM -->
                                            <div class="card-body">
                                                <form class="needs-validation" novalidate enctype="multipart/form-data" id="addForm" method="post">
                                                    <div class="form-row">
                                                        <div class="col-md-8 mb-2">
                                                            <label for="title">Role Title</label>
                                                            <input type="text" class="form-control" name="title" id="title" placeholder="Enter role title" required>
                                                        </div>
                                                        <div class="col-md-4 mt-5">
                                                            <div class="form-group pull-right mt-2">
                                                                <button type="submit" id="submit" class="btn btn-sm btn-outline-success">Save</button>
                                                                <button type="reset" class="btn btn-sm btn-outline-info reset_form">Reset</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="card" id="editRecordForm" style="display: none;">
                                            <div class="card-header">
                                                <h3 class="card-title"><i class="fe fe-edit"></i> Update Record</h3>
                                            </div>
                                            <!-- EDIT FORM -->
                                            <div class="card-body">
                                                <form class="needs-validation" novalidate enctype="multipart/form-data" id="editForm" method="post">
                                                    <input type="hidden" name="role_id_edit" id="role_id_edit" value="">
                                                    <div class="form-row">
                                                        <div class="col-md-8 mb-2">
                                                            <label for="title_edit">Role Title</label>
                                                            <input type="text" class="form-control" name="title_edit" id="title_edit" placeholder="Enter role title" required>
                                                        </div>
                                                        <div class="col-md-4 mt-5">
                                                            <div class="form-group pull-right mt-2">
                                                                <button type="submit" id="submitEdit" class="btn btn-sm btn-outline-success">Update</button>
                                                                <button type="reset" class="btn btn-sm btn-outline-info reset_form">Cancel</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- ROW 1 -->
                            </div>
                            <!-- CONTAINER END -->
                        </div>
                    </div>
                    <!--app-content close-->
                </div>

            <!-- FOOTER -->
            <%- include ('../partials/footer') %>

            <!-- FOOTER END -->
        </div>

        <!-- BACK-TO-TOP -->
        <a href="#top" id="back-to-top">
            <i class="fa fa-angle-up"></i>
        </a>
        <%- include ('../partials/footer-script') %>
    </body>
   <script>
    const actionUrl = "<%=actionUrl%>";
    $(function () {
        let table = $('#table1').DataTable({
            "searching"  : false,
            "paging"     : true,
            "responsive" : true,
            "select"     : true,
            "order"      : [[ 0, '' ]],
            "pageLength" : 20,
            "processing" : true,
            "serverSide" : true,
            "ajax": {
                "url": `${actionUrl}/list`,
                "type": "POST",
                "data": function () {}
            },
            "columnDefs": [
                {
                    "searchable": true,
                    "orderable": false,
                    "defaultContent": "-",
                    "targets": "_all"
                }
            ],
            "dom": 'Bfrtip',
        });//..... end of dataTables.
    })

    // add new day
    $(document).on("submit", "#addForm", async function (e) {
            e.preventDefault();
            let formData = new FormData();
            const title = $("#title").val();

            formData.append("title", title);
            let table = $('#table1').DataTable();
            if(title.trim != '') {
                submitBtnLoader('submit','show');
                $.ajax({
                    url: `${actionUrl}/add`,
                    type: 'POST',
                    processData: false,
                    contentType: false,
                    data: formData,
                    success: async function(response){
                        submitBtnLoader('submit','hide');
                        if(response.success) {
                            $.growl.notice1({title: "Success", message: response.message});
                            await resetForm();
                            table.draw();
                        } else {
                            $.growl.error1({title: "Error!", message: response.message});
                        }
                        // scroll top
                        window.scrollTo({top: 0, behavior: 'smooth'});
                    },
                    error: function(xhr, errmsg, err) {
                        submitBtnLoader('submit','hide');
                        $.growl.error1({title: "Error!", message: err+errmsg});
                        // scroll top
                        window.scrollTo({top: 0, behavior: 'smooth'});
                    }
                })
            }
        });

    // edit record
    function editRecord(id, table) {
        $.ajax({
            url: `/ap/general/edit/record`,
            type: 'POST',
            data: { id: id, source_table: table },
            success: function(response){
                if(response && response.success) {
                    $('#addRecordForm').css('display','none');
                    $('#editRecordForm').css('display','block');
                    $('#role_id_edit').val(id);
                    $('#title_edit').val(response.data.title);
                    // scroll top
                    window.scrollTo({top: 0, behavior: 'smooth'});
                }
            },
            error: function(xhr, errmsg, err) {
                $.growl.error1({title: "Error!", message: err+errmsg});
            }
        })
    }

    // udpate record
    $(document).on("submit", "#editForm", async function (e) {
        e.preventDefault();
        let formData = new FormData();
        const id = $("#role_id_edit").val();
        const title = $("#title_edit").val();

        formData.append("id", id);
        formData.append("title", title);
        let table = $('#table1').DataTable();
        if(id != "" && title.trim() != "") {
            submitBtnLoader('submitEdit','show');
            $.ajax({
                url: `${actionUrl}/update`,
                type: 'POST',
                processData: false,
                contentType: false,
                data: formData,
                success: async function(response){
                    submitBtnLoader('submitEdit','hide');
                    if(response.success) {
                        $.growl.notice1({title: "Success", message: response.message});
                        await resetForm();
                        table.draw();
                    } else {
                        $.growl.error1({title: "Error!", message: response.message});
                    }
                    // scroll top
                    window.scrollTo({top: 0, behavior: 'smooth'});
                },
                error: function(xhr, errmsg, err) {
                    submitBtnLoader('submitEdit','hide');
                    $.growl.error1({title: "Error!", message: err+"."+errmsg});
                }
            })
        }
    });

    // delete record hard
    function deleteRecord(id, table) {
        let table1 = $('#table1').DataTable()
            swal({
                title: "Are you sure?",
                text: "You want to delete this permanently!",
                type: "error",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }, function (result) {
                if (result) {
                    $.ajax({
                        url: `/ap/general/delete/record`,
                        type: 'POST',
                        data: {
                            id: id,
                            source_table: table
                        },
                        success: function (response) {
                            if (response && response.success) {
                                $.growl.notice1({title: "Success", message: response.message});
                                table1.draw();
                            } else {
                                $.growl.error1({title: "Error!", message: response.message});
                            }
                        },
                        error: function (xhr, errmsg, err) {
                            $.growl.error1({title: "Error!", message: response.message});
                        }
                    })
                }
            })
        }

        // RESET FORM
        $(".reset_form").click(async function () {
            await resetForm();
            // scroll top
            window.scrollTo({top: 0, behavior: 'smooth'});
        })

        // reset form
        function resetForm() {
            $('#addForm')[0].reset();
            $('#editForm')[0].reset();
            $('#role_id_edit').val('');
            $('#addRecordForm').css('display','block');
            $('#editRecordForm').css('display','none');
        }

   </script>
</html>
