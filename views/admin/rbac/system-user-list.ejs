<!doctype html>
<html lang="en" dir="ltr">
    <%- include ('../partials/head') %>
    <body class="app sidebar-mini ltr">
        <!-- PAGE -->
        <div class="page">
            <div class="page-main">
                <!-- app-Header -->
                <%- include ('../partials/header') %>
                <!-- /app-Header -->
                <!--APP-SIDEBAR-->
                <%- include ('../partials/sidebar') %>
                <!--app-content open-->
                    <div class="main-content app-content mt-0"> 
                        <div class="side-app">
                        <!-- CONTAINER -->
                        <div
                            class="main-container container-fluid">
                            
                            <!-- PAGE-HEADER -->
                            <div class="page-header">
                                
                                <h1 class="page-title">
                                    <%= pageTitle %></code>
                                </h1>
                                <div>
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item">
                                            <a href="/ap/home">Home</a>
                                        </li>
                                        <li class="breadcrumb-item                                                                                                   active" aria-current="page">
                                            <%= pageTitle %>
                                        </li>
                                    </ol>
                                </div>
                            </div>
                            <% if ( successFlash.length> 0 ) { %>
                                <div class="alert alert-success  alert-dismissible fade show" role="alert">
                                    <span class="alert-inner--icon"><i class="fe fe-thumbs-up"></i></span>
                                    <span class="alert-inner--text"><strong>Success! </strong><%= successFlash %></span>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <% } %>
                                <% if ( errorFlash.length> 0 ) { %>
                                <div class="alert alert-danger  alert-dismissible fade show" role="alert">
                                    <span class="alert-inner--icon"><i class="fe fe-info"></i></span>
                                    <span class="alert-inner--text"><strong>Error! </strong><%= errorFlash %></span>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                            <% } %>
                            <!-- PAGE-HEADER END -->
                                <!-- ROW 1 -->
                                <div class="row">
                                    <div class="col-lg-12 col-md-12">
                                        <div class="card" id="addRecordForm" style="display: block;">
                                            <div class="card-header">
                                                <h3 class="card-title"><i class="fe fe-plus-circle"></i> Add New User </h3>
                                            </div>
                                            <!-- ADD FORM -->
                                            <div class="card-body">
                                                <form class="needs-validation" novalidate enctype="multipart/form-data" id="addForm" method="post">
                                                    <div class="form-row">
                                                        <div class="col-md-4 mb-2">
                                                            <label for="name">Full Name<sup class="text-danger">*</sup></label>
                                                            <input type="text" class="form-control" name="name" id="name" placeholder="Fullname" required>
                                                        </div>
                                                        <div class="col-md-4 mb-2">
                                                            <label for="username">Username<sup class="text-danger">*</sup> <small class="text-primary">(Will be used for login)</small></label>
                                                            <input type="email" class="form-control" name="username" id="username" placeholder="Enter valid email as username" required>
                                                        </div>
                                                        <div class="col-md-4 mb-2">
                                                            <label for="password">Password<sup class="text-danger">*</sup><small class="text-danger">(Note: You will not be able to change it later)</small></label>
                                                            <input type="text" class="form-control" name="password" id="password" placeholder="Password" required>
                                                        </div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="col-md-4 mb-2">
                                                            <label for="mobile_no">Contact#<sup class="text-danger">*</sup></label>
                                                            <input type="text" name="mobile_no" id="mobile_no" class="form-control" placeholder="Mobile number" required>
                                                        </div>
                                                        <div class="col-md-4 mb-2">
                                                            <label for="role_id">Select User Role<sup class="text-danger">*</sup></label>
                                                            <select class="form-control select2-show-search select2" data-placeholder="Select Role" id="role_id" name="role_id">
                                                                <option value="0" selected disabled>Select Role</option>
                                                                <% rolesData.forEach(role => { %>
                                                                    <option value="<%=role.id%>"><%=role.title%></option>
                                                                <% }) %>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-3 mb-2">
                                                            <label for="profile_image">Profile Image<sup class="text-danger">*</sup></label>
                                                            <input type="file" class="dropify" data-bs-height="180" name="profile_image" id="profile_image"/>
                                                        </div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="col-md-12">
                                                            <div class="form-group pull-right">
                                                                <button type="submit" id="submit" class="btn btn-sm btn-outline-success">Save</button>
                                                                <button type="reset" class="btn btn-sm btn-outline-info reset_form">Reset</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="card" id="editRecordForm" style="display: none;">
                                            <div class="card-header">
                                                <h3 class="card-title"><i class="fe fe-edit"></i> Update User </h3>
                                            </div>
                                            <!-- EDIT FORM -->
                                            <div class="card-body">
                                                <form class="needs-validation" novalidate enctype="multipart/form-data" id="editForm" method="post">
                                                    <input type="hidden" name="user_id_edit" id="user_id_edit" value="">
                                                    <div class="form-row">
                                                        <div class="col-md-4 mb-2">
                                                            <label for="name">Full Name<sup class="text-danger">*</sup></label>
                                                            <input type="text" class="form-control" name="name" id="name_edit" placeholder="Fullname" required>
                                                        </div>
                                                        <div class="col-md-4 mb-2">
                                                            <label for="username">Username<sup class="text-danger">*</sup> <small class="text-primary">(Will be used for login)</small></label>
                                                            <input type="email" class="form-control" name="username" id="username_edit" placeholder="Enter valid email as username" required>
                                                        </div>
                                                        <div class="col-md-4 mb-2">
                                                            <label for="email">Email<sup class="text-danger">*</sup></label>
                                                            <input type="email" class="form-control" name="email" id="email_edit" placeholder="Email address" required>
                                                        </div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="col-md-4 mb-2">
                                                            <label for="mobile_no">Contact#<sup class="text-danger">*</sup></label>
                                                            <input type="text" name="mobile_no" id="mobile_no_edit" class="form-control" placeholder="Mobile number" required>
                                                        </div>
                                                        <div class="col-md-4 mb-2">
                                                            <label for="role_id">Select Role<sup class="text-danger">*</sup></label>
                                                            <select class="form-control select2-show-search select2" data-placeholder="Select Role" id="role_id_edit" name="role_id">
                                                                <option value="0" disabled>Select Role</option>
                                                                <% rolesData.forEach(role => { %>
                                                                    <option value="<%=role.id%>"><%=role.title%></option>
                                                                <% }) %>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-3 mb-2">
                                                            <label for="profile_image">Profile Image<sup class="text-danger">*</sup></label>
                                                            <input type="file" class="dropify dropify-edit" data-bs-height="180" name="profile_image" id="profile_image_edit"/>
                                                        </div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="col-md-12">
                                                            <div class="form-group pull-right">
                                                                <button type="submit" id="submitEdit" class="btn btn-sm btn-outline-success">Update</button>
                                                                <button type="reset" class="btn btn-sm btn-outline-info reset_form">Cancel</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- ROW 1 -->
                                <!-- ROW-2 -->
                                <div class="row">
                                    <div class="col-md-12 col-lg-12">
                                        <div class="card">
                                            <div class="card-header">
                                                <h5 class="mb-3"><%= pageTitle %> List</h5>
                                            </div>
                                            <div class="card-body">
                                                <div class="table-responsive">
                                                    <table id="table1" class="table table-sm table-hover table-condensed mb-0" width="100%">
                                                        <thead>
                                                            <tr>
                                                                <th style="width: 4%;">#</th>
                                                                <th>Name</th>
                                                                <th>Username</th>
                                                                <th>Email</th>
                                                                <th>Contact#</th>
                                                                <th>Role</th>
                                                                <th style="width: 5%;">Status</th>
                                                                <th>Created</th>
                                                                <th style="width: 10%;">Action</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody> 
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- ROW-2 END -->
                            </div>
                            <!-- CONTAINER END -->
                        </div>
                    </div>
                    <!--app-content close-->
                </div>

            <!-- FOOTER -->
            <%- include ('../partials/footer') %>

            <!-- FOOTER END -->
        </div>

        <!-- BACK-TO-TOP -->
        <a href="#top" id="back-to-top">
            <i class="fa fa-angle-up"></i>
        </a>
        <%- include ('../partials/footer-script') %>
    </body>
   <script>
    const actionUrl = "<%=actionUrl%>";
    $(function () {
        let table = $('#table1').DataTable({
            "searching"  : false,
            "paging"     : true,
            "responsive" : true,
            "select"     : true,
            "order"      : [[ 0, '' ]],
            "pageLength" : 30,
            "processing" : true,
            "serverSide" : true,
            "ajax": {
                "url": `${actionUrl}/list`,
                "type": "POST",
                "data": function () {}
            },
            "columnDefs": [
                {
                    "searchable": true,
                    "orderable": false,
                    "defaultContent": "-",
                    "targets": "_all"
                }
            ],
            "dom": 'Bfrtip',
        });//..... end of dataTables.
    })

    // add new day
    $(document).on("submit", "#addForm", async function (e) {
            e.preventDefault();
            let formData = new FormData();
            const name = $("#name").val();
            const username = $("#username").val();
            const password = $("#password").val();
            const mobileNo = $("#mobile_no").val();
            const roleId = $("#role_id").val();
            const profileImage = $('#profile_image').prop('files')[0];

            formData.append("name", name);
            formData.append("username", username);
            formData.append("password", password);
            formData.append("mobile_no", mobileNo);
            formData.append("role_id", roleId);
            formData.append("profile_image", profileImage);
            let table = $('#table1').DataTable();
            if(name.trim() != '' && username.trim() != '' && password.trim() != '') {
                submitBtnLoader('submit','show');
                $.ajax({
                    url: `${actionUrl}/add`,
                    type: 'POST',
                    processData: false,
                    contentType: false,
                    data: formData,
                    success: async function(response){
                        submitBtnLoader('submit','hide');
                        if(response.success) {
                            $.growl.notice1({title: "Success", message: response.message});
                            await resetForm();
                            table.draw();
                        } else {
                            $.growl.error1({title: "Error! 1", message: response.message});
                        }
                        // scroll top
                        window.scrollTo({top: 0, behavior: 'smooth'});
                    },
                    error: function(xhr, errmsg, err) {
                        submitBtnLoader('submit','hide');
                        $.growl.error1({title: "Error! 2", message: err+errmsg});
                        // scroll top
                        window.scrollTo({top: 0, behavior: 'smooth'});
                    }
                })
            }
        });

    // edit record
    function editRecord(id, table) {
        $.ajax({
            url: `/ap/general/edit/record`,
            type: 'POST',
            data: { id: id, source_table: table },
            success: function(response){
                if(response && response.success) {
                    $('#addRecordForm').css('display','none');
                    $('#editRecordForm').css('display','block');
                    $('.dropify-render img').remove();
                    $('#user_id_edit').val(id);
                    $('#name_edit').val(response.data.name);
                    $('#username_edit').val(response.data.username);
                    $('#email_edit').val(response.data.email);
                    $('#mobile_no_edit').val(response.data.mobile_no);
                    $('#role_id_edit').val(response.data.role_id).trigger('change');
                    if(response.data.profile_image) {
                        const profileImg = `<img src="/${response.data.profile_image}" id="dropify-img">`
                        $(".dropify-preview").css("display", "block");
                        $(".dropify-loader").css("display", "none");
                        $('.dropify-render').append(profileImg)
                        $(".dropify-clear").css("display", "block");
                        $(".dropify-wrapper").addClass("has-preview")
                    }
                    // scroll top
                    window.scrollTo({top: 0, behavior: 'smooth'});
                }
            },
            error: function(xhr, errmsg, err) {
                $.growl.error1({title: "Error!", message: err+errmsg});
            }
        })
    }

    // udpate record
    $(document).on("submit", "#editForm", async function (e) {
        e.preventDefault();
        let formData = new FormData();
        const id = $("#user_id_edit").val();
        const name = $("#name_edit").val();
        const username = $("#username_edit").val();
        const email = $("#email_edit").val();
        const mobileNo = $("#mobile_no_edit").val();
        const roleId = $("#role_id_edit").val();
        const profileImage = $('#profile_image_edit').prop('files')[0];

        formData.append("id", id);
        formData.append("name", name);
        formData.append("username", username);
        formData.append("email", email);
        formData.append("mobile_no", mobileNo);
        formData.append("role_id", roleId);
        formData.append("profile_image", profileImage);
        let table = $('#table1').DataTable();
        if(id != "" && name.trim() != '' && username.trim() != '') {
            submitBtnLoader('submitEdit','show');
            $.ajax({
                url: `${actionUrl}/update`,
                type: 'POST',
                processData: false,
                contentType: false,
                data: formData,
                success: async function(response){
                    submitBtnLoader('submitEdit','hide');
                    if(response.success) {
                        $.growl.notice1({title: "Success", message: response.message});
                        await resetForm();
                        table.draw();
                    } else {
                        $.growl.error1({title: "Error!", message: response.message});
                    }
                    // scroll top
                    window.scrollTo({top: 0, behavior: 'smooth'});
                },
                error: function(xhr, errmsg, err) {
                    submitBtnLoader('submitEdit','hide');
                    $.growl.error1({title: "Error!", message: err+"."+errmsg});
                }
            })
        }
    });

    // delete record hard
    function deleteRecord(id, table) {
        let table1 = $('#table1').DataTable()
            swal({
                title: "Are you sure?",
                text: "You want to delete this permanently!",
                type: "error",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }, function (result) {
                if (result) {
                    $.ajax({
                        url: `/ap/general/delete/record`,
                        type: 'POST',
                        data: {
                            id: id,
                            source_table: table
                        },
                        success: function (response) {
                            if (response && response.success) {
                                $.growl.notice1({title: "Success", message: response.message});
                                table1.draw();
                            } else {
                                $.growl.error1({title: "Error!", message: response.message});
                            }
                        },
                        error: function (xhr, errmsg, err) {
                            $.growl.error1({title: "Error!", message: response.message});
                        }
                    })
                }
            })
        }

        // RESET FORM
        $(".reset_form").click(async function () {
            await resetForm();
            // scroll top
            window.scrollTo({top: 0, behavior: 'smooth'});
        })

        // reset form
        function resetForm() {
            $('#addForm')[0].reset();
            $('#editForm')[0].reset();
            $('#role_id').val('0').trigger('change');
            $('#user_id_edit').val('');
            $('#addRecordForm').css('display','block');
            $('#editRecordForm').css('display','none');
            // Dropify IMAGE
            $('.dropify-render img').remove();
            $(".dropify-preview").css("display", "none");
            $(".dropify-clear").css("display", "none");
            $(".dropify-loader").css("display", "none");
            $(".dropify-message").css("display", "block")
        }

   </script>
</html>
