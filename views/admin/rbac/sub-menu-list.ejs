<!doctype html>
<html lang="en" dir="ltr">
    <%- include ('../partials/head') %>
    <body class="app sidebar-mini ltr">
        <!-- PAGE -->
        <div class="page">
            <div class="page-main">
                <!-- app-Header -->
                <%- include ('../partials/header') %>
                <!-- /app-Header -->
                <!--APP-SIDEBAR-->
                <%- include ('../partials/sidebar') %>
                <!--app-content open-->
                    <div class="main-content app-content mt-0"> 
                        <div class="side-app">
                        <!-- CONTAINER -->
                        <div
                            class="main-container container-fluid">
                            
                            <!-- PAGE-HEADER -->
                            <div class="page-header">
                                
                                <h1 class="page-title">
                                    <%= pageTitle %> for <code><%=menuData.route%></code>
                                </h1>
                                <div>
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item">
                                            <a href="/ap/home">Home</a>
                                        </li>
                                        <li class="breadcrumb-item">
                                            <a href="/ap/rbac/menus">Menus List</a>
                                        </li>
                                        <li class="breadcrumb-item                                                                                                   active" aria-current="page">
                                            <%= pageTitle %>
                                        </li>
                                    </ol>
                                </div>
                            </div>
                            <% if ( successFlash.length> 0 ) { %>
                                <div class="alert alert-success  alert-dismissible fade show" role="alert">
                                    <span class="alert-inner--icon"><i class="fe fe-thumbs-up"></i></span>
                                    <span class="alert-inner--text"><strong>Success! </strong><%= successFlash %></span>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <% } %>
                                <% if ( errorFlash.length> 0 ) { %>
                                <div class="alert alert-danger  alert-dismissible fade show" role="alert">
                                    <span class="alert-inner--icon"><i class="fe fe-info"></i></span>
                                    <span class="alert-inner--text"><strong>Error! </strong><%= errorFlash %></span>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                            <% } %>
                            <!-- PAGE-HEADER END -->
                                <!-- ROW 1 -->
                                <div class="row">
                                    <div class="col-lg-12 col-md-12">
                                        <div class="card" id="addRecordForm" style="display: block;">
                                            <div class="card-header">
                                                <h3 class="card-title"><i class="fe fe-plus-circle"></i> Add New Record for <code><%=menuData.title%></code></h3>
                                            </div>
                                            <!-- ADD FORM -->
                                            <div class="card-body">
                                                <form class="needs-validation" novalidate enctype="multipart/form-data" id="addForm" method="post">
                                                    <div class="form-row">
                                                        <div class="col-md-3 mb-2">
                                                            <label for="title">Title<sup class="text-danger">*</sup></label>
                                                            <input type="text" class="form-control" name="title" id="title" placeholder="Title" required>
                                                        </div>
                                                        <div class="col-md-3 mb-2">
                                                            <label for="route">Route<sup class="text-danger">*</sup></label>
                                                            <input type="text" class="form-control" name="route" id="route" value="<%=menuData.route%>" placeholder="<%=menuData.route%>" required>
                                                        </div>
                                                        <div class="col-md-3 mb-2">
                                                            <label for="slug">Slug<sup class="text-danger">*</sup> <code><%=menuData.route%>/</code></label>
                                                            <input type="text" class="form-control" name="slug" id="slug" placeholder="show, list, add, edit etc" required>
                                                        </div>
                                                        <div class="col-md-3 mb-2">
                                                            <label for="query_param">Query Param(s) <code>(Optional)</code></label>
                                                            <input type="text" class="form-control" name="query_param" id="query_param" placeholder="type=paid or type=paid&name=cake">
                                                        </div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="col-md-4 mb-2">
                                                            <label for="icon">Icon<sup class="text-danger">*</sup></label>
                                                            <input type="text" name="icon" id="icon" value="fe fe-circle" class="form-control" placeholder="fe fe-circle" required>
                                                        </div>
                                                        <div class="col-md-4 mb-2">
                                                            <label for="sort">Sort<sup class="text-danger">*</sup></label>
                                                            <div class="wd-200 mg-b-30">
                                                                <input class="form-control" placeholder="0 or 1 or 2 or 3 etc." min="0" type="number" id="sort" name="sort" required>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 mt-5">
                                                            <div class="form-group pull-right mt-3">
                                                                <button type="submit" id="submit" class="btn btn-sm btn-outline-success">Save</button>
                                                                <button type="reset" class="btn btn-sm btn-outline-info reset_form">Reset</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="card" id="editRecordForm" style="display: none;">
                                            <div class="card-header">
                                                <h3 class="card-title"><i class="fe fe-edit"></i> Update Record for <code><%=menuData.title%></code></h3>
                                            </div>
                                            <!-- EDIT FORM -->
                                            <div class="card-body">
                                                <form class="needs-validation" novalidate enctype="multipart/form-data" id="editForm" method="post">
                                                    <input type="hidden" name="menu_id_edit" id="menu_id_edit" value="">
                                                    <div class="form-row">
                                                        <div class="col-md-3 mb-2">
                                                            <label for="title_edit">Title<sup class="text-danger">*</sup></label>
                                                            <input type="text" class="form-control" name="title_edit" id="title_edit" placeholder="Sub Menu title" required>
                                                        </div>
                                                        <div class="col-md-3 mb-2">
                                                            <label for="route_edit">Route<sup class="text-danger">*</sup></label>
                                                            <input type="text" class="form-control" name="route_edit" id="route_edit" value="<%=menuData.route%>" placeholder="<%=menuData.route%>" required>
                                                        </div>
                                                        <div class="col-md-3 mb-2">
                                                            <label for="slug_edit">Slug<sup class="text-danger">*</sup> <code><%=menuData.route%>/</code></label>
                                                            <input type="text" class="form-control" name="slug_edit" id="slug_edit" placeholder="show, list, add, edit, etc" required>
                                                        </div>
                                                        <div class="col-md-3 mb-2">
                                                            <label for="query_param_edit">Query Param(s) <code>(Optional)</code></label>
                                                            <input type="text" class="form-control" name="query_param" id="query_param_edit" placeholder="type=paid or type=paid&name=cake">
                                                        </div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="col-md-4 mb-2">
                                                            <label for="icon_edit">Icon<sup class="text-danger">*</sup></label>
                                                            <input type="text" name="icon_edit" id="icon_edit" class="form-control" placeholder="fe fe-circle" required>
                                                        </div>
                                                        <div class="col-md-4 mb-2">
                                                            <label for="sort_edit">Sort<sup class="text-danger">*</sup></label>
                                                            <div class="wd-200 mg-b-30">
                                                                <input class="form-control" placeholder="0 or 1 or 2 or 3 etc." min="0" type="number" id="sort_edit" name="sort_edit" required>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 mt-5">
                                                            <div class="form-group pull-right mt-3">
                                                                <button type="submit" id="submitEdit" class="btn btn-sm btn-outline-success">Update</button>
                                                                <button type="reset" class="btn btn-sm btn-outline-info reset_form">Cancel</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- ROW 1 -->
                                <!-- ROW-2 -->
                                <div class="row">
                                    <div class="col-md-12 col-lg-12">
                                        <div class="card">
                                            <div class="card-header">
                                                <h5 class="mb-3"><%= pageTitle %> List for <strong><%=menuData.route%></strong></h5>
                                            </div>
                                            <div class="card-body">
                                                <div class="table-responsive">
                                                    <table id="table1" class="table table-sm table-hover table-condensed mb-0" width="100%">
                                                        <thead>
                                                            <tr>
                                                                <th>#</th>
                                                                <th>Title</th>
                                                                <th>Route</th>
                                                                <th>Slug</th>
                                                                <th>Icon</th>
                                                                <th>Sort</th>
                                                                <th>Visibility</th>
                                                                <th style="width: 10%;">Action</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody> 
                                                        </tbody>
                                                        <tfoot>
                                                            <tr>
                                                                <th>#</th>
                                                                <th>Title</th>
                                                                <th>Route</th>
                                                                <th>Slug</th>
                                                                <th>Icon</th>
                                                                <th>Sort</th>
                                                                <th>Visibility</th>
                                                                <th style="width: 10%;">Action</th>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- ROW-2 END -->
                            </div>
                            <!-- CONTAINER END -->
                        </div>
                    </div>
                    <!--app-content close-->
                </div>

            <!-- FOOTER -->
            <%- include ('../partials/footer') %>

            <!-- FOOTER END -->
        </div>

        <!-- BACK-TO-TOP -->
        <a href="#top" id="back-to-top">
            <i class="fa fa-angle-up"></i>
        </a>
        <%- include ('../partials/footer-script') %>
    </body>
   <script>
    const actionUrl = "<%=actionUrl%>";
    const menuId = "<%=menuData.id%>";
    const menuType = "<%=menuData.type%>";
    const menuRoute = "<%=menuData.route%>";
    $(function () {
        let table = $('#table1').DataTable({
            "searching"  : false,
            "paging"     : true,
            "responsive" : true,
            "select"     : true,
            "order"      : [[ 0, '' ]],
            "pageLength" : 20,
            "processing" : true,
            "serverSide" : true,
            "ajax": {
                "url": `${actionUrl}/list`,
                "type": "POST",
                "data": function (d) {
                    d.menu_id = menuId;
                }
            },
            "columnDefs": [
                {
                    "searchable": true,
                    "orderable": false,
                    "defaultContent": "-",
                    "targets": "_all"
                }
            ],
            "dom": 'Bfrtip',
        });//..... end of dataTables.
    })

    // add new day
    $(document).on("submit", "#addForm", async function (e) {
            e.preventDefault();
            let formData = new FormData();
            const title = $("#title").val();
            const route = $("#route").val();
            const slug = $("#slug").val();
            const icon = $("#icon").val();
            const sort = $("#sort").val();
            const queryParam = $("#query_param").val();

            formData.append("menu_id", menuId);
            formData.append("menu_parent_type", menuType);
            formData.append("title", title);
            formData.append("route", route);
            formData.append("slug", slug);
            formData.append("icon", icon);
            formData.append("sort", sort);
            formData.append("query_param", queryParam);
            let table = $('#table1').DataTable();
            if(title.trim != '') {
                submitBtnLoader('submit','show');
                $.ajax({
                    url: `${actionUrl}/add`,
                    type: 'POST',
                    processData: false,
                    contentType: false,
                    data: formData,
                    success: async function(response){
                        submitBtnLoader('submit','hide');
                        if(response.success) {
                            $.growl.notice1({title: "Success", message: response.message});
                            await resetForm();
                            table.draw();
                        } else {
                            $.growl.error1({title: "Error!", message: response.message});
                        }
                        // scroll top
                        window.scrollTo({top: 0, behavior: 'smooth'});
                    },
                    error: function(xhr, errmsg, err) {
                        submitBtnLoader('submit','hide');
                        $.growl.error1({title: "Error!", message: err+errmsg});
                        // scroll top
                        window.scrollTo({top: 0, behavior: 'smooth'});
                    }
                })
            }
        });

    // edit record
    function editRecord(id, table) {
        $.ajax({
            url: `/ap/general/edit/record`,
            type: 'POST',
            data: { id: id, source_table: table },
            success: function(response){
                if(response && response.success) {
                    $('#addRecordForm').css('display','none');
                    $('#editRecordForm').css('display','block');
                    $('#menu_id_edit').val(id);
                    $('#title_edit').val(response.data.title);
                    $('#route_edit').val(response.data.route);
                    $('#slug_edit').val(response.data.slug);
                    $('#icon_edit').val(response.data.icon);
                    $('#sort_edit').val(response.data.sort);
                    $('#query_param_edit').val(response.data.query_param);
                    // scroll top
                    window.scrollTo({top: 0, behavior: 'smooth'});
                }
            },
            error: function(xhr, errmsg, err) {
                $.growl.error1({title: "Error!", message: err+errmsg});
            }
        })
    }

    // udpate record
    $(document).on("submit", "#editForm", async function (e) {
        e.preventDefault();
        let formData = new FormData();
        const id = $("#menu_id_edit").val();
        const parent_id = menuId;
        const title = $("#title_edit").val();
        const route = $("#route_edit").val();
        const slug = $("#slug_edit").val();
        const icon = $("#icon_edit").val();
        const sort = $("#sort_edit").val();
        const queryParam = $("#query_param_edit").val();

        formData.append("id", id);
        formData.append("parent_id", parent_id);
        formData.append("menu_parent_type", menuType);
        formData.append("title", title);
        formData.append("route", route);
        formData.append("slug", slug);
        formData.append("icon", icon);
        formData.append("sort", sort);
        formData.append("query_param", queryParam);
        let table = $('#table1').DataTable();
        if(id != "" && title.trim() != "") {
            submitBtnLoader('submitEdit','show');
            $.ajax({
                url: `${actionUrl}/update`,
                type: 'POST',
                processData: false,
                contentType: false,
                data: formData,
                success: async function(response){
                    submitBtnLoader('submitEdit','hide');
                    if(response.success) {
                        $.growl.notice1({title: "Success", message: response.message});
                        await resetForm();
                        table.draw();
                    } else {
                        $.growl.error1({title: "Error!", message: response.message});
                    }
                    // scroll top
                    window.scrollTo({top: 0, behavior: 'smooth'});
                },
                error: function(xhr, errmsg, err) {
                    submitBtnLoader('submitEdit','hide');
                    $.growl.error1({title: "Error!", message: err+"."+errmsg});
                }
            })
        }
    });

    // delete record hard
    function deleteRecord(id, table) {
        let table1 = $('#table1').DataTable()
            swal({
                title: "Are you sure?",
                text: "You want to delete this permanently!",
                type: "error",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }, function (result) {
                if (result) {
                    $.ajax({
                        url: `/ap/general/delete/record`,
                        type: 'POST',
                        data: {
                            id: id,
                            source_table: table
                        },
                        success: function (response) {
                            if (response && response.success) {
                                $.growl.notice1({title: "Success", message: response.message});
                                table1.draw();
                            } else {
                                $.growl.error1({title: "Error!", message: response.message});
                            }
                        },
                        error: function (xhr, errmsg, err) {
                            $.growl.error1({title: "Error!", message: response.message});
                        }
                    })
                }
            })
        }

        // RESET FORM
        $(".reset_form").click(async function () {
            await resetForm();
            // scroll top
            window.scrollTo({top: 0, behavior: 'smooth'});
        })

        // reset form
        function resetForm() {
            $('#addForm')[0].reset();
            $('#editForm')[0].reset();
            $('#menu_id_edit').val('');
            $('#addRecordForm').css('display','block');
            $('#editRecordForm').css('display','none');
        }

   </script>
</html>
