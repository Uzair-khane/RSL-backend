<!DOCTYPE html>
<html lang="en" dir="ltr">
  <%- include ('../partials/head') %>
  <body class="app sidebar-mini ltr">
    <!-- PAGE -->
    <div class="page">
      <div class="page-main">
        <!-- app-Header -->
        <%- include ('../partials/header') %>
        <!-- /app-Header -->
        <!--APP-SIDEBAR-->
        <%- include ('../partials/sidebar') %>
        <!--app-content open-->
        <div class="main-content app-content mt-0">
          <div class="side-app">
            <!-- CONTAINER -->
            <div class="main-container container-fluid">
              <!-- PAGE-HEADER -->
              <div class="page-header">
                <h1 class="page-title"><%= pageTitle %></h1>
                <div>
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                      <a href="/ap/home">Home</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                      <%= pageTitle %>
                    </li>
                  </ol>
                </div>
              </div>
              <!-- PAGE-HEADER END -->
              <!-- ROW 1 -->
              <div class="row">
                <div class="col-lg-12 col-md-12">
                  <div class="card" id="addRecordForm" style="display: block">
                    <div class="card-header">
                      <h3 class="card-title">
                        <i class="fe fe-plus-circle"></i> Add New Cars
                      </h3>
                    </div>
                    <!-- ADD FORM -->
                    <div class="card-body">
                      <form
                        class=""
                        enctype="multipart/form-data"
                        id="addForm"
                        method="post"
                      >
                        <div class="form-row">
                          <div class="col-md-4 mb-2">
                            <label for="title"
                              >Title<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="title"
                              id="title"
                              placeholder="Enter main title"
                              required
                            />
                          </div>
                          <div class="col-md-4 mb-2">
                            <label
                              >Select Type News or Event<small class="text-info"></small
                            ></label>
                            <select
                              class="form-control select2-show-search select2 type-dropdown"
                              data-placeholder="Select Type"
                              id="type"
                              name="type"
                            >
                              <option value="" selected disabled>
                                Select Type For News or Event
                              </option>
                              <option value="news">News</option>
                              <option value="event">Event</option>
                            </select>
                          </div>
                          <div class="col-md-4 mb-2">
                            <label for="image_url"
                              >Display Image<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="file"
                              class="dropify"
                              data-bs-height="180"
                              name="image_url"
                              id="image_url"
                            />
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12 mb-2">
                            <label for="description">Description</label>
                            <textarea
                              class="form-control mb-4 summernote"
                              required
                              id="description"
                              name="description"
                            ></textarea>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12">
                            <div class="form-group pull-right">
                              <button
                                type="submit"
                                id="submit"
                                class="btn btn-sm btn-outline-success"
                              >
                                Save
                              </button>
                              <button
                                type="reset"
                                class="btn btn-sm btn-outline-info reset_form"
                              >
                                Reset
                              </button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                  <div class="card" id="editRecordForm" style="display: none">
                    <div class="card-header">
                      <h3 class="card-title">
                        <i class="fe fe-edit"></i> Update Record
                      </h3>
                    </div>
                    <!-- EDIT FORM -->
                    <div class="card-body">
                      <form
                        class=""
                        enctype="multipart/form-data"
                        id="editForm"
                        method="post"
                      >
                        <input
                          type="hidden"
                          name="news_event_id_edit"
                          id="news_event_id_edit"
                          value=""
                        />
                        <div class="form-row">
                          <div class="col-md-4 mb-2">
                            <label for="title_edit"
                              >Title<sup class="text-danger">*</sup></label
                            >
                            <input
                              type="text"
                              class="form-control"
                              name="title"
                              id="title_edit"
                              placeholder="Enter main title"
                              required
                            />
                          </div>
                          <div class="col-md-4 mb-2">
                            <label
                              >Select Type For News or Event<small class="text-info"></small
                            ></label>
                            <select
                              class="form-control select2-show-search select2 type-dropdown"
                              data-placeholder="Select Type"
                              id="type_edit"
                              name="type"
                            >
                              <option value="" selected disabled>
                                Select Type For News or Event
                              </option>
                              <option value="news">News</option>
                              <option value="event">Event</option>
                            </select>
                          </div>
                          <div class="col-md-4 mb-2">
                            <label for="image_url_edit"
                              >Display Image<sup class="text-danger"
                                >*</sup
                              ></label
                            >
                            <input
                              type="file"
                              class="dropify"
                              data-bs-height="180"
                              name="image_url"
                              id="image_url_edit"
                            />
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12 mb-2">
                            <label for="description_edit">Description</label>
                            <textarea
                              class="form-control mb-4 summernote"
                              required
                              name="description"
                              id="description_edit"
                            ></textarea>
                          </div>
                        </div>
                        <div class="form-row">
                          <div class="col-md-12">
                            <div class="form-group pull-right">
                              <button
                                type="submit"
                                id="submitEdit"
                                class="btn btn-sm btn-outline-success"
                              >
                                Update
                              </button>
                              <button
                                type="reset"
                                class="btn btn-sm btn-outline-info reset_form"
                              >
                                Cancel
                              </button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW 1 -->
              <!-- ROW-2 -->
              <div class="row">
                <div class="col-md-12 col-lg-12">
                  <div class="card">
                    <div class="card-header">
                      <h5 class="mb-3"><%= pageTitle %> List</h5>
                    </div>
                    <div class="card-body">
                      <div class="table-responsive">
                        <table
                          id="table1"
                          class="table table-sm table-hover table-condensed"
                          width="100%"
                        >
                          <thead>
                            <tr>
                              <th style="width: 4%">#</th>
                              <th style="width: 8%">Title</th>
                              <th>Type</th>
                              <th>Image</th>
                              <th style="width: 18%">Description</th>
                              <th >Status</th>
                              <th>Created</th>
                              <th>Updated</th>
                              <th style="width: 10%">Action</th>
                            </tr>
                          </thead>
                          <tbody></tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- ROW-2 END -->
            </div>
            <!-- CONTAINER END -->
          </div>
        </div>
        <!--app-content close-->
      </div>

      <!-- FOOTER -->
      <%- include ('../partials/footer') %>

      <!-- FOOTER END -->
    </div>

    <!-- BACK-TO-TOP -->
    <a href="#top" id="back-to-top">
      <i class="fa fa-angle-up"></i>
    </a>
    <%- include ('../partials/footer-script') %>
  </body>
  <script>
    const actionUrl = "<%=actionUrl%>";
    $(function () {
      let table = $("#table1").DataTable({
        searching: false,
        paging: true,
        responsive: true,
        select: true,
        order: [[0, ""]],
        pageLength: 30,
        processing: true,
        serverSide: true,
        ajax: {
          url: `${actionUrl}/list`,
          type: "POST",
          data: function () {},
        },
        columnDefs: [
          {
            searchable: true,
            orderable: false,
            defaultContent: "-",
            targets: "_all",
          },
        ],
        dom: "Bfrtip",
      }); //..... end of dataTables.
    });

    // add new day
    $(document).on("submit", "#addForm", async function (e) {
      e.preventDefault();
      let formData = new FormData();
      const title = $("#title").val();
      const type = $("#type").val();
      const previewImage = $("#image_url").prop("files")[0];
      const description = $("#description").summernote("code");

      formData.append("title", title);
      formData.append("type", type);
      formData.append("image_url", previewImage);
      formData.append("description", description);
      let table = $("#table1").DataTable();
      if (title.trim() != "") {
        submitBtnLoader("submit", "show");
        $.ajax({
          url: `${actionUrl}/add`,
          type: "POST",
          processData: false,
          contentType: false,
          data: formData,
          success: async function (response) {
            submitBtnLoader("submit", "hide");
            if (response.success) {
              $.growl.notice1({ title: "Success", message: response.message });
              await resetForm();
              table.draw();
            } else {
              $.growl.error1({ title: "Error! 1", message: response.message });
            }
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          },
          error: function (xhr, errmsg, err) {
            submitBtnLoader("submit", "hide");
            $.growl.error1({ title: "Error! 2", message: err + errmsg });
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          },
        });
      }
    });

    // edit record
    function editRecord(id, table) {
      $.ajax({
        url: `/ap/general/edit/record`,
        type: "POST",
        data: { id: id, source_table: table },
        success: function (response) {
          if (response && response.success) {
            $("#addRecordForm").css("display", "none");
            $("#editRecordForm").css("display", "block");
            $(".dropify-render img").remove();
            $("#news_event_id_edit").val(id);
            $("#title_edit").val(response.data.title);
            $("#type_edit").val(response.data.type).trigger("change");
            // $('#type_edit').val(response.data.type).trigger('change');
            $("#description_edit").summernote(
              "code",
              response.data.description
            );
            if (response.data.image) {
              const pImg = `<img src="/${response.data.image}" id="dropify-img">`;
              $(".dropify-preview").css("display", "block");
              $(".dropify-loader").css("display", "none");
              $(".dropify-render").append(pImg);
              $(".dropify-clear").css("display", "block");
              $(".dropify-wrapper").addClass("has-preview");
            }
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        },
        error: function (xhr, errmsg, err) {
          $.growl.error1({ title: "Error!", message: err + errmsg });
        },
      });
    }

    // udpate record
    $(document).on("submit", "#editForm", async function (e) {
      e.preventDefault();
      let formData = new FormData();
      const id = $("#news_event_id_edit").val();
      const title = $("#title_edit").val();
      const type = $("#type_edit").val();
      const description = $("#description_edit").summernote("code");
      const previewImage = $("#image_url_edit").prop("files")[0];

      formData.append("id", id);
      formData.append("title", title);
      formData.append("type", type);
      formData.append("description", description);
      formData.append("image_url", previewImage);
      let table = $("#table1").DataTable();
      if (id != "" && title.trim() != "") {
        submitBtnLoader("submitEdit", "show");
        $.ajax({
          url: `${actionUrl}/update`,
          type: "POST",
          processData: false,
          contentType: false,
          data: formData,
          success: async function (response) {
            submitBtnLoader("submitEdit", "hide");
            if (response.success) {
              $.growl.notice1({ title: "Success", message: response.message });
              await resetForm();
              table.draw();
            } else {
              $.growl.error1({ title: "Error!", message: response.message });
            }
            // scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
          },
          error: function (xhr, errmsg, err) {
            submitBtnLoader("submitEdit", "hide");
            $.growl.error1({ title: "Error!", message: err + "." + errmsg });
          },
        });
      }
    });

    // delete record hard
    function deleteRecord(id, table) {
      let table1 = $("#table1").DataTable();
      swal(
        {
          title: "Are you sure?",
          text: "You want to delete this permanently!",
          type: "error",
          icon: "warning",
          showCancelButton: true,
          confirmButtonText: "Yes, delete it!",
          cancelButtonText: "Cancel",
        },
        function (result) {
          if (result) {
            $.ajax({
              url: `/ap/general/delete/record`,
              type: "POST",
              data: {
                id: id,
                source_table: table,
              },
              success: function (response) {
                if (response && response.success) {
                  $.growl.notice1({
                    title: "Success",
                    message: response.message,
                  });
                  table1.draw();
                } else {
                  $.growl.error1({
                    title: "Error!",
                    message: response.message,
                  });
                }
              },
              error: function (xhr, errmsg, err) {
                $.growl.error1({ title: "Error!", message: response.message });
              },
            });
          }
        }
      );
    }

    // RESET FORM
    $(".reset_form").click(async function () {
      await resetForm();
      // scroll top
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // reset form
    function resetForm() {
      $("#addForm")[0].reset();
      $("#editForm")[0].reset();
      $(".summernote").summernote("code", "");
      $("#news_events_id_edit").val("");
      $("#type").val("footer").trigger("change");
      $("#type_edit").val("footer").trigger("change");
      $("#addRecordForm").css("display", "block");
      $("#editRecordForm").css("display", "none");
      // Dropify IMAGE
      $(".dropify-render img").remove();
      $(".dropify-preview").css("display", "none");
      $(".dropify-clear").css("display", "none");
      $(".dropify-loader").css("display", "none");
      $(".dropify-message").css("display", "block");
    }
  </script>
</html>
