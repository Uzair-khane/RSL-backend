<!doctype html>
<html lang="en" dir="ltr">

<%- include ('partials/head') %>


    <body class="app sidebar-mini ltr ">

        <!-- PAGE -->
        <div class="page">
            <div class="page-main">

                <!-- app-Header -->
                <%- include ('partials/header') %>

                    <!-- /app-Header -->

                    <!--APP-SIDEBAR-->
                    <%- include ('partials/sidebar') %>


                        <!--app-content open-->
                        <div class="main-content app-content mt-0">
                            <div class="side-app">

                                <!-- CONTAINER -->
                                <div class="main-container container-fluid">
                                    <!-- PAGE-HEADER -->
                                    <div class="page-header">
                                        <h1 class="page-title">
                                            <%= pageTitle %>
                                        </h1>
                                        <div>
                                            <ol class="breadcrumb">
                                                <li class="breadcrumb-item">
                                                    <a href="/ap/home">Home</a>
                                                </li>
                                                <li class="breadcrumb-item                                                                                                   active"
                                                    aria-current="page">
                                                    <%= pageTitle %>
                                                </li>
                                            </ol>
                                        </div>
                                    </div>
                                    <!-- PAGE-HEADER END -->
                                    <!-- ROW-2 -->

                                    <div class="row">
                                        <div class="col-lg-12">
                                            <div class="card">
                                                <div class="card-header">
                                                    <h3 class="card-title">Feedback</h3>
                                                </div>
                                                <div class="card-body">
                                                    <div class="table-responsive">
                                                        <div id="autofill-table_wrapper"
                                                            class="dataTables_wrapper dt-bootstrap5">
                                                            
                                                            <div class="row">
                                                                <div class="col-sm-12">
                                                                    <table id="replytable"
                                                                        class="table table-bordered text-nowrap w-100"
                                                                        role="grid"
                                                                        aria-describedby="autofill-table_info">
                                                                        <thead>
                                                                            <tr role="row">
                                                                                <th>Id</th>
                                                                                <th>Name</th>
                                                                                <th>Email</th>
                                                                                <th>Description</th>
                                                                                <th>Action</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>

                                                                        </tbody>

                                                                    </table>

                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                    <!-- ROW-2 END -->
                                </div>
                                <!-- CONTAINER END -->
                            </div>
                        </div>
                        <!--app-content close-->
            </div>


            <!-- Modal -->

            <div class="modal fade" id="scrollingmodal" tabindex="-1" role="dialog">
                <div class="modal-dialog modal-dialog-scrollable modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header position-relative d-flex justify-content-center">
                            <h5>Feedback Detail</h5>
                            <button class="btn-close position-absolute end-0" data-bs-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">×</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="d-flex justify-content-between">
                                <div class="d-flex gap-3">
                                 <label for="">Name: </label>
                                 <h6 id="name"></h6>
                                </div>
                               <div class="d-flex gap-3 align-items-center">
                                <label for="">Date/Time: </label>
                                <h6 id="date"></h6>
                               </div>
                             
                            </div>
                            <div class="align-items-center d-flex gap-3">
                                <label for="">Email: </label>
                                <h6 id="email"></h6>
                            </div>
                            <div class="description">
                                <label class="d-block " for="">Description: </label>
                                <p id="description" class="text-justify">
                                   
                                </p>
                               </div>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FOOTER -->
            <%- include ('partials/footer') %>

                <!-- FOOTER END -->
        </div>

        <!-- BACK-TO-TOP -->
        <a href="#top" id="back-to-top">
            <i class="fa fa-angle-up"></i>
        </a>
        <%- include ('partials/footer-script') %>


    </body>
    <script>
        function viewTableData(id) {
            $("#name").val('')
            $("#email").val('')
            $("#description").val('')
            $.ajax({
                url: `<%=baseUrl%>/feedback/view/${id}`,
                type: "get",
                success: function (response) {
                    $("#data").text(response.data.feedData.email)
                    $("#name").text(response.data.feedData.full_name)
                    $("#email").text(response.data.feedData.email)
                    $("#description").text(response.data.feedData.description)
                    $("#date").text(moment(response.data.feedData.updatedAt).format("LLL"))
                    $('#scrollingmodal').modal('show');
                },
                error: function (xhr, errmsg, err) {
                    console.log("err")
                },
            });

        }
        $(function () {
            viewrecord();
        })
        function viewrecord() {
            let table = $('#replytable').DataTable({
                "searching": true,
                "paging": true,
                "responsive": true,
                "select": true,
                "order": [[0, 'desc']],
                "pageLength": 10,
                "processing": true,
                "destroy": true,
                "serverSide": true,
                "ajax": {
                    "url": `<%=baseUrl%>/feedback/list`,
                    "type": "POST",
                    "data": function () { }
                },
                "columnDefs": [
                    {
                        "searchable": true,
                        "orderable": false,
                        "defaultContent": "-",
                        "targets": "_all"
                    }
                ],
                "dom": 'Bfrtip',
            });//..... end of dataTables.
        }


    </script>

</html>