<div class="app-header header sticky">
  <div class="container-fluid main-container">
    <div class="d-flex">
      <a
        aria-label="Hide Sidebar"
        class="app-sidebar__toggle"
        data-bs-toggle="sidebar"
        href="javascript:void(0)"
      ></a>
      <!-- sidebar-toggle-->
      <a class="logo-horizontal" href="/ap/home">
        <img
          src="/favicon/favicon-32x32.png"
          class="header-brand-img desktop-logo"
          alt="logo"
        />
        <img
          src="/favicon/favicon-32x32.png"
          class="header-brand-img light-logo1"
          alt="logo"
        />
      </a>
      <!-- LOGO -->
      <div class="d-flex order-lg-2 ms-auto header-right-icons">
        <!-- SEARCH -->
        <button
          class="navbar-toggler navresponsive-toggler d-lg-none ms-auto"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarSupportedContent-4"
          aria-controls="navbarSupportedContent-4"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon fe fe-more-vertical"></span>
        </button>
        <div class="navbar navbar-collapse responsive-navbar p-0">
          <div class="collapse navbar-collapse" id="navbarSupportedContent-4">
            <div class="d-flex order-lg-2">
              <div class="dropdown d-flex">
                <a class="nav-link icon full-screen-link nav-link-bg">
                  <i class="fe fe-minimize fullscreen-button"></i>
                </a>
              </div>
              <!-- FULL-SCREEN -->
              <div class="dropdown d-flex notifications">
                <a class="nav-link icon" data-bs-toggle="dropdown"
                  ><i class="fe fe-bell"></i><span class="pulse"></span
                ></a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                  <div class="drop-heading border-bottom">
                    <div class="d-flex">
                      <h6 class="mt-1 mb-0 fs-16 fw-semibold text-dark">
                        Notifications
                      </h6>
                    </div>
                  </div>
                  <div class="dropdown-divider m-0"></div>                

                 <% if(notificationList && notificationList.length > 0) { %> 
                    <% notificationList?.forEach(element => { %>
                  <div class="d-flex justify-content-between m-3">
                    <span>New Booking From</span>
                    <span><%= element.name %></span>
                  </div>
                  <hr />
                  <% }); %>
                   <% } else{ %>
                  <a href="#" class="dropdown-item text-center p-3 text-muted"
                    >No new notification!</a
                  >
                  <% } %>
                </div>
              </div>
              <!-- NOTIFICATIONS -->
              <!-- SIDE-MENU -->
              <div class="dropdown d-flex profile-1">
                <% if(currentUser && currentUser.profile_image != null){ %>
                <a
                  href="javascript:void(0)"
                  data-bs-toggle="dropdown"
                  class="nav-link leading-none d-flex"
                >
                  <img
                    src="/<%=currentUser.profile_image%>"
                    alt="profile-user"
                    class="avatar profile-user brround cover-image"
                  />
                </a>
                <% } else { %>
                <a class="nav-link icon" data-bs-toggle="dropdown"
                  ><i class="fe fe-user"></i>
                </a>
                <% } %>
                <div
                  class="dropdown-menu dropdown-menu-end dropdown-menu-arrow"
                >
                  <div class="drop-heading">
                    <div class="text-center">
                      <h5 class="text-dark mb-0 fs-14 fw-semibold">
                        <%=currentUser.name%>
                      </h5>
                      <small class="text-muted"
                        ><%=currentUser.roles.title%></small
                      >
                    </div>
                  </div>
                  <div class="dropdown-divider m-0"></div>
                  <a class="dropdown-item" href="/ap/profile/edit">
                    <i class="dropdown-icon fe fe-user"></i> Profile
                  </a>
                  <a class="dropdown-item" href="/ap/auth/logout">
                    <i class="dropdown-icon fe fe-alert-circle"></i> Sign out
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script></script>
